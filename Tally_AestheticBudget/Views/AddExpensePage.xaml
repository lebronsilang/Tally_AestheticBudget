<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Tally_AestheticBudget.Views.AddExpensePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Tally_AestheticBudget.ViewModels"
    x:DataType="vm:AddExpenseViewModel"
    Shell.NavBarIsVisible="True"
    BackgroundColor="#80000000">

    <!-- Dimmed backdrop — tap to cancel -->
    <Grid>
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding CancelCommand}" />
        </Grid.GestureRecognizers>

        <!-- Centered modal card -->
        <Border BackgroundColor="{StaticResource CardBackground}"
                StrokeThickness="0" StrokeShape="RoundRectangle 16"
                HorizontalOptions="Center" VerticalOptions="Center"
                MaximumWidthRequest="360"
                Margin="20,0">
            <ScrollView MaximumHeightRequest="580">
                <VerticalStackLayout Padding="18,16,18,18" Spacing="12">

                    <!-- Header -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="1">
                            <Label Text="{Binding PageTitle}" FontFamily="DisplayFont"
                                   FontSize="18" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{Binding IsEditMode, Converter={StaticResource BoolToEditSubtitle}}"
                                   FontSize="11" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" BackgroundColor="{StaticResource PageBackground}"
                                StrokeThickness="0" StrokeShape="RoundRectangle 980"
                                WidthRequest="28" HeightRequest="28" VerticalOptions="Start">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CancelCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="✕" FontSize="12" TextColor="{StaticResource TextSecondary}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <!-- Title -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Title" FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Border BackgroundColor="{StaticResource PageBackground}"
                                Stroke="{StaticResource CardBorder}"
                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10" Padding="12,0">
                            <Entry Text="{Binding Title}" Placeholder="e.g. Lunch with friends"
                                   PlaceholderColor="#C0C0C5" FontSize="13"
                                   TextColor="{StaticResource TextPrimary}"
                                   BackgroundColor="Transparent" HeightRequest="40" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Amount -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Amount (₱)" FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Border BackgroundColor="{StaticResource PageBackground}"
                                Stroke="{StaticResource CardBorder}"
                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10" Padding="12,0">
                            <Entry Text="{Binding AmountText}" Placeholder="0.00"
                                   PlaceholderColor="#C0C0C5" Keyboard="Numeric" FontSize="13"
                                   TextColor="{StaticResource TextPrimary}"
                                   BackgroundColor="Transparent" HeightRequest="40" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Category -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Category" FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start" AlignItems="Center">
                            <Border BackgroundColor="{Binding IsFoodSelected, Converter={StaticResource BoolToChipBg}}"
                                    Stroke="{Binding IsFoodSelected, Converter={StaticResource BoolToChipBorder}}"
                                    StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                    Padding="12,6" Margin="0,0,6,6">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCategoryCommand}" CommandParameter="Food" />
                                </Border.GestureRecognizers>
                                <Label Text="🍜 Food" FontSize="12"
                                       TextColor="{Binding IsFoodSelected, Converter={StaticResource BoolToChipText}}" />
                            </Border>
                            <Border BackgroundColor="{Binding IsTransportSelected, Converter={StaticResource BoolToChipBg}}"
                                    Stroke="{Binding IsTransportSelected, Converter={StaticResource BoolToChipBorder}}"
                                    StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                    Padding="12,6" Margin="0,0,6,6">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCategoryCommand}" CommandParameter="Transport" />
                                </Border.GestureRecognizers>
                                <Label Text="🚌 Transport" FontSize="12"
                                       TextColor="{Binding IsTransportSelected, Converter={StaticResource BoolToChipText}}" />
                            </Border>
                            <Border BackgroundColor="{Binding IsShoppingSelected, Converter={StaticResource BoolToChipBg}}"
                                    Stroke="{Binding IsShoppingSelected, Converter={StaticResource BoolToChipBorder}}"
                                    StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                    Padding="12,6" Margin="0,0,6,6">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCategoryCommand}" CommandParameter="Shopping" />
                                </Border.GestureRecognizers>
                                <Label Text="🛍️ Shopping" FontSize="12"
                                       TextColor="{Binding IsShoppingSelected, Converter={StaticResource BoolToChipText}}" />
                            </Border>
                            <Border BackgroundColor="{Binding IsHealthSelected, Converter={StaticResource BoolToChipBg}}"
                                    Stroke="{Binding IsHealthSelected, Converter={StaticResource BoolToChipBorder}}"
                                    StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                    Padding="12,6" Margin="0,0,6,6">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCategoryCommand}" CommandParameter="Health" />
                                </Border.GestureRecognizers>
                                <Label Text="💊 Health" FontSize="12"
                                       TextColor="{Binding IsHealthSelected, Converter={StaticResource BoolToChipText}}" />
                            </Border>
                            <Border BackgroundColor="{Binding IsFunSelected, Converter={StaticResource BoolToChipBg}}"
                                    Stroke="{Binding IsFunSelected, Converter={StaticResource BoolToChipBorder}}"
                                    StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                    Padding="12,6" Margin="0,0,6,6">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCategoryCommand}" CommandParameter="Fun" />
                                </Border.GestureRecognizers>
                                <Label Text="🎬 Fun" FontSize="12"
                                       TextColor="{Binding IsFunSelected, Converter={StaticResource BoolToChipText}}" />
                            </Border>
                            <Border BackgroundColor="{Binding IsOtherSelected, Converter={StaticResource BoolToChipBg}}"
                                    Stroke="{Binding IsOtherSelected, Converter={StaticResource BoolToChipBorder}}"
                                    StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                    Padding="12,6" Margin="0,0,6,6">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCategoryCommand}" CommandParameter="Other" />
                                </Border.GestureRecognizers>
                                <Label Text="✨ Other" FontSize="12"
                                       TextColor="{Binding IsOtherSelected, Converter={StaticResource BoolToChipText}}" />
                            </Border>
                        </FlexLayout>
                    </VerticalStackLayout>

                    <!-- Note -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Note (optional)" FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Border BackgroundColor="{StaticResource PageBackground}"
                                Stroke="{StaticResource CardBorder}"
                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10" Padding="12,0">
                            <Entry Text="{Binding Note}" Placeholder="Any extra details..."
                                   PlaceholderColor="#C0C0C5" FontSize="13"
                                   TextColor="{StaticResource TextPrimary}"
                                   BackgroundColor="Transparent" HeightRequest="40" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Date -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Date" FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Border BackgroundColor="{StaticResource PageBackground}"
                                Stroke="{StaticResource CardBorder}"
                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10" Padding="12,4">
                            <DatePicker Date="{Binding SelectedDate}" Format="MMMM dd, yyyy"
                                        FontSize="13" TextColor="{StaticResource TextPrimary}"
                                        BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Photo -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Photo (optional)" FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Border IsVisible="{Binding HasPhoto, Converter={StaticResource InverseBool}}"
                                BackgroundColor="{StaticResource PageBackground}"
                                Stroke="{StaticResource CardBorder}"
                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10" HeightRequest="72">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PickPhotoCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="3">
                                <Label Text="📷" FontSize="20" HorizontalOptions="Center" />
                                <Label Text="Tap to add a photo" FontSize="11"
                                       TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <VerticalStackLayout IsVisible="{Binding HasPhoto}" Spacing="0">
                            <Border BackgroundColor="{StaticResource PageBackground}"
                                    Stroke="{StaticResource CardBorder}"
                                    StrokeThickness="0.8" StrokeShape="RoundRectangle 10" Padding="0">
                                <Grid RowDefinitions="Auto,Auto">
                                    <Image Grid.Row="0" Source="{Binding PhotoPath}"
                                           Aspect="AspectFill" HeightRequest="110">
                                        <Image.Clip>
                                            <RoundRectangleGeometry Rect="0,0,1000,110" CornerRadius="10,10,0,0" />
                                        </Image.Clip>
                                    </Image>
                                    <Border Grid.Row="1" BackgroundColor="#1Fff3b30" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 0,0,10,10" Padding="0,7">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding RemovePhotoCommand}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="✕ Remove photo" FontSize="12"
                                               TextColor="#ff3b30" HorizontalOptions="Center" />
                                    </Border>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- Save -->
                    <Border BackgroundColor="{StaticResource AccentColor}" StrokeThickness="0"
                            Style="{StaticResource HoverButton}"
                            StrokeShape="RoundRectangle 980" Padding="0,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SaveCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="{Binding SaveButtonLabel}" FontSize="13" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" />
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
        </Border>
    </Grid>

</ContentPage>

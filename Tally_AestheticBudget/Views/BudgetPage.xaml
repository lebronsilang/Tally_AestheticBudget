<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Tally_AestheticBudget.Views.BudgetPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Tally_AestheticBudget.ViewModels"
    xmlns:models="clr-namespace:Tally_AestheticBudget.Models"
    x:DataType="vm:BudgetViewModel"
    Shell.NavBarIsVisible="True"
    BackgroundColor="{DynamicResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ── Floating header card ───────────────────────────────────── -->
            <Border BackgroundColor="{DynamicResource CardBackground}"
                    Stroke="{DynamicResource CardBorder}"
                    StrokeThickness="1" StrokeShape="RoundRectangle 20"
                    Padding="20,18,20,16" Margin="16,16,16,0">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Budget Overview" FontFamily="DisplayFont"
                                   FontSize="28" TextColor="{DynamicResource TextPrimary}" />
                            <Label Text="Track limits per category"
                                   FontSize="13" TextColor="{DynamicResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                Style="{StaticResource HoverButton}"
                                BackgroundColor="{DynamicResource AccentColorAlpha}"
                                Stroke="{DynamicResource AccentColor}"
                                StrokeThickness="0.8" StrokeShape="RoundRectangle 980"
                                Padding="14,8" VerticalOptions="Center">
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="Total: " FontSize="13"
                                       TextColor="{DynamicResource TextPrimary}" />
                                <Label Text="{Binding TotalSpentLabel}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{DynamicResource AccentColor}" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,16,0,0">
                        <Border Grid.Column="0"
                                Style="{StaticResource HoverButton}"
                                BackgroundColor="{DynamicResource PageBackground}"
                                StrokeShape="RoundRectangle 980"
                                WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PreviousMonthCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="‹" FontSize="20" TextColor="{DynamicResource TextPrimary}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Column="1" Text="{Binding MonthLabel}"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border Grid.Column="2"
                                Style="{StaticResource HoverButton}"
                                BackgroundColor="{DynamicResource PageBackground}"
                                StrokeShape="RoundRectangle 980"
                                WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding NextMonthCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="›" FontSize="20" TextColor="{DynamicResource TextPrimary}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ── Category list ──────────────────────────────────────────── -->
            <VerticalStackLayout Padding="16,16,16,40" Spacing="12"
                     Margin="16,16,16,0"
                     HorizontalOptions="Fill">

                <CollectionView ItemsSource="{Binding BudgetItems}" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="7" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:BudgetCategoryItem">

                            <Border BackgroundColor="{DynamicResource CardBackground}"
                        Stroke="{DynamicResource CardBorder}"
                        StrokeThickness="0.5"
                        StrokeShape="RoundRectangle 18"
                        Padding="18,16"
                        Margin="0,0,0,16">

                                <VerticalStackLayout Spacing="10">

                                    <!-- HEADER ROW -->
                                    <Grid ColumnDefinitions="Auto,*,Auto">

                                        <!-- PNG ICON (FIXED HERE) -->
                                        <Image Grid.Column="0"
                                   Source="{Binding CategoryIcon}"
                                   WidthRequest="24"
                                   HeightRequest="24"
                                   VerticalOptions="Center"
                                   Margin="0,0,10,0" />

                                        <!-- CATEGORY TEXT -->
                                        <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2"
                                                 VerticalOptions="Center">

                                            <Label Text="{Binding CategoryLabel}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource TextPrimary}" />

                                            <Label Text="{Binding StatusLabel}"
                                       FontSize="12"
                                       TextColor="{DynamicResource TextSecondary}" />

                                        </VerticalStackLayout>

                                        <!-- EDIT BUTTON -->
                                        <Border Grid.Column="2"
                                    IsVisible="{Binding IsNotEditing}"
                                    Style="{StaticResource HoverButton}"
                                    BackgroundColor="Transparent"
                                    Padding="8,4">

                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BudgetViewModel}}, Path=StartEditCommand}"
                                        CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>

                                            <Image Source="icon_add.png"
                                                   WidthRequest="16" HeightRequest="16"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />

                                        </Border>

                                    </Grid>

                                    <!-- PROGRESS BAR -->
                                    <Grid HeightRequest="8">

                                        <Border BackgroundColor="{DynamicResource AccentColorAlpha}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 980"
                                    HeightRequest="8" />

                                        <Border BackgroundColor="{Binding IsOverLimit, Converter={StaticResource BoolToProgressColor}}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 980"
                                    HeightRequest="8"
                                    HorizontalOptions="Start"
                                    WidthRequest="{Binding ProgressPercent, Converter={StaticResource PercentToWidth}}" />

                                    </Grid>

                                    <!-- INLINE EDIT ROW -->
                                    <Grid IsVisible="{Binding IsEditing}"
                              ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="8">

                                        <Border Grid.Column="0"
                                    BackgroundColor="{DynamicResource PageBackground}"
                                    Stroke="{DynamicResource CardBorder}"
                                    StrokeThickness="0.8"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12,0">

                                            <Entry Text="{Binding EditLimitText}"
                                       Placeholder="{Binding LimitPlaceholder}"
                                       PlaceholderColor="#C0C0C5"
                                       Keyboard="Numeric"
                                       FontSize="14"
                                       TextColor="{DynamicResource TextPrimary}"
                                       BackgroundColor="Transparent"
                                       HeightRequest="40" />

                                        </Border>

                                        <Border Grid.Column="1"
                                    Style="{StaticResource HoverButton}"
                                    BackgroundColor="{DynamicResource AccentColor}"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="14,10">

                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BudgetViewModel}}, Path=SaveLimitCommand}"
                                        CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>

                                            <Label Text="Save"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="White" />

                                        </Border>

                                        <Border Grid.Column="2"
                                    Style="{StaticResource HoverButton}"
                                    BackgroundColor="{DynamicResource PageBackground}"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="14,10">

                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BudgetViewModel}}, Path=CancelEditCommand}"
                                        CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>

                                            <Label Text="Cancel"
                                       FontSize="13"
                                       TextColor="{DynamicResource TextSecondary}" />

                                        </Border>

                                    </Grid>

                                </VerticalStackLayout>
                            </Border>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Tally_AestheticBudget.Views.FeedPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Tally_AestheticBudget.ViewModels"
    xmlns:models="clr-namespace:Tally_AestheticBudget.Models"
    x:DataType="vm:FeedViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#f5f5f7">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Grid
            Grid.Row="0"
            Padding="24,52,24,0"
            ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="10">

            <!-- Left: title + subtitle -->
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label
                    Text="My Spending Journal"
                    FontFamily="DisplayFont"
                    FontSize="28"
                    TextColor="#1d1d1f" />
                <Label
                    Text="{Binding SummaryLabel}"
                    FontSize="13"
                    TextColor="#6e6e73" />
            </VerticalStackLayout>

            <!-- Middle: Spent pill -->
            <Border
                Grid.Column="1"
                BackgroundColor="#1Fff6b6b"
                Stroke="#ff6b6b"
                StrokeThickness="0.8"
                StrokeShape="RoundRectangle 980"
                Padding="14,8"
                VerticalOptions="Center">
                <HorizontalStackLayout Spacing="4">
                    <Label Text="Spent: " FontSize="13" TextColor="#1d1d1f" />
                    <Label
                        Text="{Binding TotalSpentFormatted}"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="#ff6b6b" />
                </HorizontalStackLayout>
            </Border>

            <!-- Right: + Add button -->
            <Border
                Grid.Column="2"
                BackgroundColor="#ff6b6b"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 980"
                Padding="16,8"
                VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToAddExpenseCommand}" />
                </Border.GestureRecognizers>
                <Label
                    Text="+ Add"
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="White" />
            </Border>

        </Grid>


        <!-- ── Filter chips ───────────────────────────────────────────────── -->
        <ScrollView
            Grid.Row="1"
            Orientation="Horizontal"
            HorizontalScrollBarVisibility="Never"
            Margin="0,14,0,4">
            <HorizontalStackLayout Padding="24,0" Spacing="8">

                <!-- All -->
                <Border
                    BackgroundColor="{Binding IsFilterAll, Converter={StaticResource BoolToChipBg}}"
                    Stroke="{Binding IsFilterAll, Converter={StaticResource BoolToChipBorder}}"
                    StrokeShape="RoundRectangle 980"
                    StrokeThickness="0.8"
                    Padding="16,7">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FilterAllCommand}" />
                    </Border.GestureRecognizers>
                    <Label
                        Text="All"
                        FontSize="14"
                        FontAttributes="{Binding IsFilterAll, Converter={StaticResource BoolToFontAttr}}"
                        TextColor="{Binding IsFilterAll, Converter={StaticResource BoolToChipText}}" />
                </Border>

                <!-- Month -->
                <Border
                    BackgroundColor="{Binding IsFilterMonth, Converter={StaticResource BoolToChipBg}}"
                    Stroke="{Binding IsFilterMonth, Converter={StaticResource BoolToChipBorder}}"
                    StrokeShape="RoundRectangle 980"
                    StrokeThickness="0.8"
                    Padding="16,7">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowMonthPickerCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="5">
                        <Label
                            Text="{Binding SelectedMonthLabel}"
                            FontSize="14"
                            FontAttributes="{Binding IsFilterMonth, Converter={StaticResource BoolToFontAttr}}"
                            TextColor="{Binding IsFilterMonth, Converter={StaticResource BoolToChipText}}" />
                        <Label
                            Text="▾"
                            FontSize="11"
                            TextColor="{Binding IsFilterMonth, Converter={StaticResource BoolToChipText}}"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- This Year -->
                <Border
                    BackgroundColor="{Binding IsFilterYear, Converter={StaticResource BoolToChipBg}}"
                    Stroke="{Binding IsFilterYear, Converter={StaticResource BoolToChipBorder}}"
                    StrokeShape="RoundRectangle 980"
                    StrokeThickness="0.8"
                    Padding="16,7">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FilterYearCommand}" />
                    </Border.GestureRecognizers>
                    <Label
                        Text="{Binding ThisYearLabel}"
                        FontSize="14"
                        FontAttributes="{Binding IsFilterYear, Converter={StaticResource BoolToFontAttr}}"
                        TextColor="{Binding IsFilterYear, Converter={StaticResource BoolToChipText}}" />
                </Border>

            </HorizontalStackLayout>
        </ScrollView>

        <!-- ── Feed content ───────────────────────────────────────────────── -->
        <RefreshView
            Grid.Row="2"
            Command="{Binding RefreshCommand}"
            IsRefreshing="{Binding IsRefreshing}">
            <Grid>

                <!-- Empty state — matches .empty-state in your CSS -->
                <VerticalStackLayout
                    IsVisible="{Binding HasNoEntries}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Spacing="12"
                    Padding="40">
                    <Label
                        Text="🌸"
                        FontSize="48"
                        HorizontalOptions="Center" />
                    <Label
                        Text="No entries yet. Add your first expense!"
                        FontSize="15"
                        HorizontalOptions="Center"
                        TextColor="#6e6e73" />
                </VerticalStackLayout>

                <!-- 2-column card grid -->
                <CollectionView
                    IsVisible="{Binding HasNoEntries, Converter={StaticResource InverseBool}}"
                    ItemsSource="{Binding FeedItems}"
                    SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout
                            Orientation="Vertical"
                            Span="2"
                            HorizontalItemSpacing="12"
                            VerticalItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.Header>
                        <BoxView HeightRequest="8" Color="Transparent" />
                    </CollectionView.Header>
                    <CollectionView.Footer>
                        <BoxView HeightRequest="100" Color="Transparent" />
                    </CollectionView.Footer>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:FeedCardItem">
                            <ContentView Padding="0">
                                <ContentView.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=OpenDetailCommand}"
                                        CommandParameter="{Binding .}" />
                                </ContentView.GestureRecognizers>

                                <!-- .card in your CSS: white bg, border-radius 18px, box-shadow -->
                                <Border
                                    BackgroundColor="#ffffff"
                                    StrokeThickness="0.8"
                                    Stroke="#E8E8ED"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="0">

                                    <Grid RowDefinitions="Auto,Auto,Auto">

                                        <!-- Photo -->
                                        <Image
                                            Grid.Row="0"
                                            Source="{Binding PhotoPath}"
                                            IsVisible="{Binding HasPhoto}"
                                            Aspect="AspectFill"
                                            HeightRequest="120">
                                            <Image.Clip>
                                                <RoundRectangleGeometry Rect="0,0,1000,120" CornerRadius="18,18,0,0" />
                                            </Image.Clip>
                                        </Image>

                                        <!-- Card body — .card-body { padding: 12px 14px 14px } -->
                                        <VerticalStackLayout
                                            Grid.Row="1"
                                            Padding="{Binding HasPhoto, Converter={StaticResource PhotoToPadding}}"
                                            Spacing="4">

                                            <!-- Category label — .card-cat: accent color, uppercase, small -->
                                            <HorizontalStackLayout Spacing="6">
                                                <Label
                                                    Text="{Binding CategoryLabel}"
                                                    FontSize="11"
                                                    FontAttributes="Bold"
                                                    CharacterSpacing="0.5"
                                                    TextTransform="Uppercase"
                                                    TextColor="#ff6b6b" />
                                                <!-- Grocery item count badge -->
                                                <Border
                                                    IsVisible="{Binding IsGroceryGroup}"
                                                    BackgroundColor="#1Fff6b6b"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 980"
                                                    Padding="6,2">
                                                    <Label
                                                        Text="{Binding GroceryItemCountLabel}"
                                                        FontSize="10"
                                                        TextColor="#ff6b6b" />
                                                </Border>
                                            </HorizontalStackLayout>

                                            <!-- Note — .card-note -->
                                            <Label
                                                Text="{Binding Note}"
                                                IsVisible="{Binding HasNote}"
                                                FontSize="13"
                                                LineBreakMode="TailTruncation"
                                                MaxLines="2"
                                                TextColor="#1d1d1f" />

                                            <!-- Amount — .card-amount -->
                                            <Label
                                                Text="{Binding AmountFormatted}"
                                                FontSize="18"
                                                FontAttributes="Bold"
                                                TextColor="#1d1d1f" />

                                        </VerticalStackLayout>

                                        <!-- Date — .card-date -->
                                        <Label
                                            Grid.Row="2"
                                            Text="{Binding Date, Converter={StaticResource DateToDisplay}}"
                                            FontSize="11"
                                            Margin="14,0,14,14"
                                            TextColor="#6e6e73" />

                                    </Grid>
                                </Border>
                            </ContentView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </Grid>
        </RefreshView>

        <!-- ── Month picker overlay ────────────────────────────────────────── -->
        <Grid Grid.RowSpan="3" IsVisible="{Binding IsMonthPickerVisible}" BackgroundColor="#80000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding DismissMonthPickerCommand}" />
            </Grid.GestureRecognizers>
            <Border
                BackgroundColor="#ffffff"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 20"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="16,0,16,48"
                Padding="24,24">
                <VerticalStackLayout Spacing="16">

                    <Label
                        Text="Select month"
                        FontSize="17"
                        FontAttributes="Bold"
                        TextColor="#1d1d1f" />

                    <!-- Year row -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="28">
                        <Label Text="‹" FontSize="24" TextColor="#1d1d1f" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PreviousYearCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Text="{Binding PickerYear}" FontSize="16" VerticalOptions="Center" TextColor="#1d1d1f" />
                        <Label Text="›" FontSize="24" TextColor="#1d1d1f" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding NextYearCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                    <!-- Month grid -->
                    <CollectionView ItemsSource="{Binding MonthOptions}" SelectionMode="None" HeightRequest="180">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="4"
                                             HorizontalItemSpacing="8" VerticalItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:MonthOption">
                                <Border
                                    BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToChipBg}}"
                                    Stroke="{Binding IsSelected, Converter={StaticResource BoolToChipBorder}}"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="0.8"
                                    Padding="0,9">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=SelectMonthCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Label
                                        Text="{Binding ShortName}"
                                        FontSize="13"
                                        HorizontalOptions="Center"
                                        TextColor="{Binding IsSelected, Converter={StaticResource BoolToChipText}}" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ── Detail bottom sheet ─────────────────────────────────────────── -->
        <Grid Grid.RowSpan="3" IsVisible="{Binding IsDetailVisible}" BackgroundColor="#80000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding DismissDetailCommand}" />
            </Grid.GestureRecognizers>
            <Border
                BackgroundColor="#ffffff"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24,24,0,0"
                VerticalOptions="End">
                <Grid RowDefinitions="Auto,Auto,*">

                    <!-- Drag handle -->
                    <BoxView
                        Grid.Row="0"
                        WidthRequest="36" HeightRequest="4" CornerRadius="2"
                        Color="#DDDDE0"
                        HorizontalOptions="Center"
                        Margin="0,12,0,0" />

                    <!-- Detail header -->
                    <Grid Grid.Row="1" Padding="24,16,24,0" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label
                                Text="{Binding SelectedItem.CategoryLabel}"
                                FontSize="12"
                                FontAttributes="Bold"
                                CharacterSpacing="0.5"
                                TextTransform="Uppercase"
                                TextColor="#ff6b6b" />
                            <Label
                                Text="{Binding SelectedItem.AmountFormatted}"
                                FontSize="30"
                                FontAttributes="Bold"
                                TextColor="#1d1d1f" />
                        </VerticalStackLayout>

                        <!-- Delete button -->
                        <Border
                            Grid.Column="1"
                            BackgroundColor="#1Fff3b30"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            Padding="14,9"
                            VerticalOptions="Start">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding DeleteSelectedCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="Delete Entry" FontSize="13" TextColor="#ff3b30" />
                        </Border>
                    </Grid>

                    <!-- Scrollable detail content -->
                    <ScrollView Grid.Row="2" Padding="24,14,24,48">
                        <VerticalStackLayout Spacing="0">

                            <!-- Photo -->
                            <Image
                                Source="{Binding SelectedItem.PhotoPath}"
                                IsVisible="{Binding SelectedItem.HasPhoto}"
                                Aspect="AspectFill"
                                HeightRequest="220"
                                Margin="0,0,0,16">
                                <Image.Clip>
                                    <RoundRectangleGeometry Rect="0,0,1000,220" CornerRadius="14" />
                                </Image.Clip>
                            </Image>

                            <BoxView HeightRequest="0.5" Color="#E8E8ED" Margin="0,0,0,16" />

                            <!-- Date + category -->
                            <Grid ColumnDefinitions="*,*" Margin="0,0,0,16">
                                <VerticalStackLayout Grid.Column="0" Spacing="3">
                                    <Label Text="Date" FontSize="12" TextColor="#6e6e73" />
                                    <Label Text="{Binding SelectedItem.DateFormatted}" FontSize="15" TextColor="#1d1d1f" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label Text="Category" FontSize="12" TextColor="#6e6e73" />
                                    <Label Text="{Binding SelectedItem.CategoryLabel}" FontSize="15" TextColor="#1d1d1f" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Note -->
                            <VerticalStackLayout IsVisible="{Binding SelectedItem.HasNote}" Margin="0,0,0,16" Spacing="3">
                                <Label Text="Note" FontSize="12" TextColor="#6e6e73" />
                                <Label Text="{Binding SelectedItem.Note}" FontSize="15" TextColor="#1d1d1f" />
                            </VerticalStackLayout>

                            <!-- Grocery items -->
                            <VerticalStackLayout IsVisible="{Binding SelectedItem.IsGroceryGroup}">
                                <BoxView HeightRequest="0.5" Color="#E8E8ED" Margin="0,0,0,14" />
                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                                    <Label Grid.Column="0" Text="Items"
                                           FontSize="15" FontAttributes="Bold" TextColor="#1d1d1f" />
                                    <Label Grid.Column="1" Text="Delete all"
                                           FontSize="13" TextColor="#ff3b30">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding DeleteAllGroceryItemsCommand}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                                <CollectionView ItemsSource="{Binding SelectedItem.GroceryItems}" SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:GroceryLineItem">
                                            <Grid ColumnDefinitions="*,Auto,Auto" Padding="0,10,0,10">
                                                <BoxView Grid.ColumnSpan="3" HeightRequest="0.5"
                                                         VerticalOptions="End" Color="#F0F0F5" />
                                                <Label Grid.Column="0" Text="{Binding Name}"
                                                       FontSize="14" VerticalOptions="Center" TextColor="#1d1d1f" />
                                                <Label Grid.Column="1" Text="{Binding PriceFormatted}"
                                                       FontSize="14" FontAttributes="Bold"
                                                       TextColor="#ff6b6b"
                                                       Margin="0,0,14,0" VerticalOptions="Center" />
                                                <Label Grid.Column="2" Text="✕" FontSize="14" TextColor="#6e6e73">
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=DeleteGroceryItemCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </Label.GestureRecognizers>
                                                </Label>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </ScrollView>

                </Grid>
            </Border>
        </Grid>

    </Grid>
</ContentPage>

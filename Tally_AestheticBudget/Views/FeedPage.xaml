                        </Border>

                    </FlexLayout>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ── Day picker overlay ─────────────────────────────────────────── -->
        <Grid IsVisible="{Binding IsDayPickerVisible}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding DismissDayPickerCommand}" />
            </Grid.GestureRecognizers>
            <controls:BlurOverlay />
            <Border BackgroundColor="{DynamicResource CardBackground}"
                    Style="{StaticResource ModalCard}"
                    StrokeShape="RoundRectangle 20"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    MaximumWidthRequest="340"
                    Margin="20,0" Padding="24,24">
                <!-- Stop tap from dismissing when user taps inside card -->
                <Border.GestureRecognizers>
                    <TapGestureRecognizer />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="20">

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Pick a date" FontSize="17" FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}" />
                        <Label Text="Filter expenses for a specific day"
                               FontSize="12" TextColor="{DynamicResource TextSecondary}" />
                    </VerticalStackLayout>

                    <Border BackgroundColor="{DynamicResource PageBackground}"
                            Stroke="{DynamicResource CardBorder}"
                            StrokeThickness="0.8" StrokeShape="RoundRectangle 12"
                            Padding="12,4">
                        <DatePicker Date="{Binding PickerDay}"
                                    Format="MMMM dd, yyyy"
                                    FontSize="14"
                                    TextColor="{DynamicResource TextPrimary}"
                                    BackgroundColor="Transparent"
                                    MaximumDate="{x:Static sys:DateTime.Today}" />
                    </Border>

                    <Border BackgroundColor="{DynamicResource AccentColor}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 980" Padding="0,13">
                        <Border.Behaviors>
                            <behaviors:PressScaleBehavior />
                        </Border.Behaviors>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ConfirmDayPickerCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="Apply" FontSize="14" FontAttributes="Bold"
                               TextColor="{DynamicResource OnAccentColor}" HorizontalOptions="Center" />
                    </Border>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ── Week picker overlay ────────────────────────────────────────── -->
        <Grid IsVisible="{Binding IsWeekPickerVisible}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding DismissWeekPickerCommand}" />
            </Grid.GestureRecognizers>
            <controls:BlurOverlay />
            <Border BackgroundColor="{DynamicResource CardBackground}"
                    Style="{StaticResource ModalCard}"
                    StrokeShape="RoundRectangle 20"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    MaximumWidthRequest="340"
                    Margin="20,0" Padding="24,24">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="20">

                    <VerticalStackLayout Spacing="12">
                        <Label Text="Pick a week" FontSize="17" FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}" />
                        <Label Text="Showing the last 8 weeks"
                               FontSize="12" TextColor="{DynamicResource TextSecondary}" />
                    </VerticalStackLayout>

                    <CollectionView ItemsSource="{Binding WeekOptions}"
                                   SelectionMode="None"
                                   MaximumHeightRequest="380">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:WeekOption">
                                <Border BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding IsSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 12" StrokeThickness="0.8"
                                        Padding="14,11" Margin="0,0,0,6">
                                    <Border.Behaviors>
                                        <behaviors:PressScaleBehavior />
                                    </Border.Behaviors>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=SelectWeekCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="{Binding Label}" FontSize="13"
                                           FontAttributes="{Binding IsSelected, Converter={StaticResource BoolToFontAttr}}"
                                           TextColor="{Binding IsSelected, Converter={StaticResource BoolToChipText}}" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ── Year picker overlay ────────────────────────────────────────── -->
        <Grid IsVisible="{Binding IsYearPickerVisible}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding DismissYearPickerCommand}" />
            </Grid.GestureRecognizers>
            <controls:BlurOverlay />
            <Border BackgroundColor="{DynamicResource CardBackground}"
                    Style="{StaticResource ModalCard}"
                    StrokeShape="RoundRectangle 20"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    MaximumWidthRequest="300"
                    Margin="20,0" Padding="24,24">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="20">

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Pick a year" FontSize="17" FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}" />
                        <Label Text="Filter expenses for a specific year"
                               FontSize="12" TextColor="{DynamicResource TextSecondary}" />
                    </VerticalStackLayout>

                    <CollectionView ItemsSource="{Binding YearList}"
                                   SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="3"
                                             HorizontalItemSpacing="8"
                                             VerticalItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:Int32">
                                <Border BackgroundColor="{DynamicResource PageBackground}"
                                        Stroke="{DynamicResource CardBorder}"
                                        StrokeShape="RoundRectangle 12" StrokeThickness="0.8"
                                        Padding="0,12" HeightRequest="48">
                                    <Border.Behaviors>
                                        <behaviors:PressScaleBehavior />
                                    </Border.Behaviors>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=SelectYearCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="{Binding .}" FontSize="14"
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           TextColor="{DynamicResource TextPrimary}" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>
        </Grid>

            </Grid>
        </controls:DrawerHost.BodyContent>

        <!-- ── Detail panel content ──────────────────────────────────────── -->
        <controls:DrawerHost.DrawerContent>
            <Border BackgroundColor="{DynamicResource CardBackground}"
                    StrokeThickness="0"
                    HorizontalOptions="Fill" VerticalOptions="Fill">
                <Grid>
                <ScrollView>
                    <VerticalStackLayout Spacing="0">

                        <!-- Full-bleed photo with gradient overlay — category · date, title, amount
                             directly on the photo, matching the Wishlist detail panel's hierarchy -->
                        <Grid IsVisible="{Binding SelectedItem.HasPhoto}">
                            <Image Source="{Binding SelectedItem.PhotoPath}"
                                   Aspect="AspectFill" HeightRequest="280">
                                <Image.Clip>
                                    <RoundRectangleGeometry Rect="0,0,2000,280"
                                                            CornerRadius="16,16,0,0" />
                                </Image.Clip>
                            </Image>

                            <BoxView HeightRequest="280" InputTransparent="True">
                                <BoxView.Clip>
                                    <RoundRectangleGeometry Rect="0,0,2000,280"
                                                            CornerRadius="16,16,0,0" />
                                </BoxView.Clip>
                                <BoxView.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="Transparent" Offset="0.0" />
                                        <GradientStop Color="#40000000" Offset="0.45" />
                                        <GradientStop Color="#CC000000" Offset="1.0" />
                                    </LinearGradientBrush>
                                </BoxView.Background>
                            </BoxView>

                            <VerticalStackLayout Spacing="2" VerticalOptions="End"
                                                  Padding="18,0,18,16">
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="{Binding SelectedItem.CategoryLabel}"
                                           FontSize="11" FontAttributes="Bold"
                                           CharacterSpacing="0.5" TextTransform="Uppercase"
                                           TextColor="#CCFFFFFF" />
                                    <Label Text="·" FontSize="11" TextColor="#99FFFFFF" />
                                    <Label Text="{Binding SelectedItem.DateFormatted}"
                                           FontSize="11" TextColor="#99FFFFFF" />
                                </HorizontalStackLayout>

                                <Label Text="{Binding SelectedItem.Title}"
                                       IsVisible="{Binding SelectedItem.HasTitle}"
                                       FontSize="17" FontAttributes="Bold"
                                       TextColor="#FFFFFF" Margin="0,4,0,0" />
                                <Label Text="{Binding SelectedItem.AmountFormatted}"
                                       FontSize="20" FontAttributes="Bold"
                                       TextColor="#FFFFFF" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- No-photo fallback: same info, plain layout, no overlay -->
                        <VerticalStackLayout Padding="18,18,18,0" Spacing="2"
                                             IsVisible="{Binding SelectedItem.HasPhoto, Converter={StaticResource InverseBool}}">
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="{Binding SelectedItem.CategoryLabel}"
                                       FontSize="11" FontAttributes="Bold"
                                       CharacterSpacing="0.5" TextTransform="Uppercase"
                                       TextColor="{DynamicResource AccentColor}" />
                                <Label Text="·" FontSize="11" TextColor="{DynamicResource TextSecondary}" />
                                <Label Text="{Binding SelectedItem.DateFormatted}"
                                       FontSize="11" TextColor="{DynamicResource TextSecondary}" />
                            </HorizontalStackLayout>

                            <Label Text="{Binding SelectedItem.Title}"
                                   IsVisible="{Binding SelectedItem.HasTitle}"
                                   FontSize="18" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" Margin="0,4,0,0" />
                            <Label Text="{Binding SelectedItem.AmountFormatted}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Padding="18,14,18,18" Spacing="10">

                            <Border IsVisible="{Binding SelectedItem.HasRegretRating}"
                                    BackgroundColor="{Binding SelectedItem.IsWorthIt, Converter={StaticResource BoolToAffordBg}}"
                                    Stroke="{Binding SelectedItem.IsWorthIt, Converter={StaticResource BoolToAffordText}}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12,10">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                    <Label Grid.Column="0"
                                           Text="{x:Static ph:PhosphorIcons.Heart}"
                                           FontFamily="PhosphorIcons" FontSize="17"
                                           TextColor="{Binding SelectedItem.IsWorthIt, Converter={StaticResource BoolToAffordText}}"
                                           VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                        <Label Text="BOUGHT FROM YOUR WISHLIST"
                                               FontSize="9.5" FontAttributes="Bold" CharacterSpacing="0.6"
                                               TextColor="{Binding SelectedItem.IsWorthIt, Converter={StaticResource BoolToAffordText}}"
                                               Opacity="0.8" />
                                        <Label Text="{Binding SelectedItem.RegretLabel}"
                                               FontSize="14.5" FontAttributes="Bold"
                                               TextColor="{Binding SelectedItem.IsWorthIt, Converter={StaticResource BoolToAffordText}}" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2"
                                           Text="{Binding SelectedItem.RegretIcon}"
                                           FontFamily="PhosphorIcons" FontSize="22"
                                           TextColor="{Binding SelectedItem.IsWorthIt, Converter={StaticResource BoolToAffordText}}"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>

                            <BoxView HeightRequest="0.5" Color="{DynamicResource CardBorder}" />

                            <VerticalStackLayout Spacing="10">

                                <VerticalStackLayout IsVisible="{Binding SelectedItem.HasTitle}" Spacing="3">
                                    <Label Text="Title" FontSize="10"
                                           TextColor="{DynamicResource TextSecondary}" />
                                    <Label Text="{Binding SelectedItem.Title}"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="{DynamicResource TextPrimary}" />
                                </VerticalStackLayout>

                                <Grid ColumnDefinitions="*,*">
                                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                                        <Label Text="Date" FontSize="10"
                                               TextColor="{DynamicResource TextSecondary}" />
                                        <Label Text="{Binding SelectedItem.DateFormatted}"
                                               FontSize="13" TextColor="{DynamicResource TextPrimary}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                                        <Label Text="Category" FontSize="10"
                                               TextColor="{DynamicResource TextSecondary}" />
                                        <Label Text="{Binding SelectedItem.CategoryLabel}"
                                               FontSize="13" TextColor="{DynamicResource TextPrimary}" />
                                    </VerticalStackLayout>
                                </Grid>

                                <VerticalStackLayout IsVisible="{Binding SelectedItem.HasNote}" Spacing="3">
                                    <Label Text="Note" FontSize="10"
                                           TextColor="{DynamicResource TextSecondary}" />
                                    <Label Text="{Binding SelectedItem.Note}"
                                           FontSize="13" TextColor="{DynamicResource TextPrimary}" />
                                </VerticalStackLayout>

                            </VerticalStackLayout>

                            <BoxView HeightRequest="0.5" Color="{DynamicResource CardBorder}" />

                            <Grid ColumnDefinitions="*,Auto"
                                  IsVisible="{Binding SelectedItem.IsGroceryGroup, Converter={StaticResource InverseBool}}">
                                <Label Grid.Column="0" Text="Edit" FontSize="13"
                                       TextColor="{DynamicResource AccentColor}">
                                    <Label.Behaviors>
                                        <behaviors:PressScaleBehavior />
                                    </Label.Behaviors>
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding GoToEditExpenseCommand}"
                                                              CommandParameter="{Binding SelectedItem}" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label Grid.Column="1" Text="Delete" FontSize="13" TextColor="#ff3b30">
                                    <Label.Behaviors>
                                        <behaviors:PressScaleBehavior />
                                    </Label.Behaviors>
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding DeleteSelectedCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>

                            <VerticalStackLayout IsVisible="{Binding SelectedItem.IsGroceryGroup}"
                                                 Margin="0,0,0,0">
                                <BoxView HeightRequest="0.5" Color="{DynamicResource CardBorder}"
                                         Margin="0,0,0,10" />
                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                    <Label Grid.Column="0" Text="Items"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="{DynamicResource TextPrimary}" />
                                    <Label Grid.Column="1" Text="Delete all"
                                           FontSize="12" TextColor="#ff3b30">
                                        <Label.Behaviors>
                                            <behaviors:PressScaleBehavior />
                                        </Label.Behaviors>
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding DeleteAllGroceryItemsCommand}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                                <CollectionView ItemsSource="{Binding SelectedItem.GroceryItems}"
                                               SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:GroceryLineItem">
                                            <Grid ColumnDefinitions="*,Auto,Auto" Padding="0,8,0,8">
                                                <BoxView Grid.ColumnSpan="3" HeightRequest="0.5"
                                                         VerticalOptions="End"
                                                         Color="{DynamicResource CardBorder}" />
                                                <Label Grid.Column="0" Text="{Binding Name}"
                                                       FontSize="13" VerticalOptions="Center"
                                                       TextColor="{DynamicResource TextPrimary}" />
                                                <Label Grid.Column="1" Text="{Binding PriceFormatted}"
                                                       FontSize="13" FontAttributes="Bold"
                                                       TextColor="{DynamicResource AccentColor}"
                                                       Margin="0,0,12,0" VerticalOptions="Center" />
                                                <Label Grid.Column="2" Text="✕" FontSize="13"
                                                       TextColor="{DynamicResource TextSecondary}">
                                                    <Label.Behaviors>
                                                        <behaviors:PressScaleBehavior />
                                                    </Label.Behaviors>
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=DeleteGroceryItemCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </Label.GestureRecognizers>
                                                </Label>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- Floating close button, mirrors the Wishlist detail panel's close button -->
                <Border BackgroundColor="#33000000" StrokeThickness="0"
                        StrokeShape="RoundRectangle 980"
                        WidthRequest="30" HeightRequest="30"
                        HorizontalOptions="End" VerticalOptions="Start"
                        Margin="0,14,14,0">
                    <Border.Behaviors>
                        <behaviors:PressScaleBehavior />
                    </Border.Behaviors>
                    <Label Text="✕" FontSize="14" TextColor="#FFFFFF"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding DismissDetailCommand}" />
                    </Border.GestureRecognizers>
                </Border>
                </Grid>
            </Border>
        </controls:DrawerHost.DrawerContent>
    </controls:DrawerHost>
</ContentPage>
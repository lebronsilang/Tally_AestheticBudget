<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Tally_AestheticBudget.Views.FeedPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Tally_AestheticBudget.ViewModels"
    xmlns:models="clr-namespace:Tally_AestheticBudget.Models"
    xmlns:controls="clr-namespace:Tally_AestheticBudget.Controls"
    xmlns:ph="clr-namespace:Tally_AestheticBudget.Helpers"
    xmlns:behaviors="clr-namespace:Tally_AestheticBudget.Behaviors"
    x:DataType="vm:FeedViewModel"
    Shell.NavBarIsVisible="True"
    BackgroundColor="{DynamicResource PageBackground}">

    <!-- ── Outer drawer: item detail panel ─────────────────────────────────── -->
    <controls:DrawerHost
        IsOpen="{Binding IsDetailVisible}"
        OpenFromLeft="False"
        DrawerWidth="420"
        CloseCommand="{Binding DismissDetailCommand}">

        <controls:DrawerHost.BodyContent>
            <Grid>

        <controls:DrawerHost
            Grid.RowSpan="2"
            IsOpen="{Binding IsExpensePanelOpen}"
            OpenFromLeft="{Binding ExpensePanelOnLeft}"
            DrawerWidth="380"
            CloseCommand="{Binding DismissExpensePanelCommand}">

            <controls:DrawerHost.BodyContent>
                <Grid>

                    <!-- Empty state -->
                    <VerticalStackLayout
            IsVisible="{Binding HasNoEntries}"
            HorizontalOptions="Center" VerticalOptions="Center"
            Spacing="12" Padding="40">
                        <Image Source="icon_sakura.png"
               WidthRequest="48"
               HeightRequest="48"
               HorizontalOptions="Center" />
                        <Label Text="No entries yet. Add your first expense!"
                   FontSize="15" HorizontalOptions="Center"
                   TextColor="{DynamicResource TextSecondary}" />
                    </VerticalStackLayout>

                    <!-- Main scrollable content -->
                    <ScrollView
                        x:Name="MasonryScrollView">

                        <VerticalStackLayout Spacing="0">

                            <!-- ── Floating header card ───────────────────────────────── -->
                            <Border
                    BackgroundColor="{DynamicResource CardBackground}"
                    Stroke="{DynamicResource CardBorder}"
                    StrokeThickness="1" StrokeShape="RoundRectangle 20"
                    Padding="20,16,20,12"
                    Margin="16,16,16,12">
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="My Spending Journal"
                                       FontFamily="DisplayFont" FontSize="28"
                                       TextColor="{DynamicResource TextPrimary}" />
                                            <Label Text="{Binding SummaryLabel}"
                                       FontSize="13"
                                       TextColor="{DynamicResource TextSecondary}" />
                                        </VerticalStackLayout>
                                        <Border Grid.Column="1"
                                    Style="{StaticResource HoverButton}"
                                    BackgroundColor="{DynamicResource AccentColorAlpha}"
                                    Stroke="{DynamicResource AccentColor}"
                                    StrokeThickness="0.8" StrokeShape="RoundRectangle 980"
                                    Padding="14,8" VerticalOptions="Center">
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="Spent: " FontSize="13"
                                           TextColor="{DynamicResource TextPrimary}" />
                                                <Label Text="{Binding TotalSpentFormatted}"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="{DynamicResource AccentColor}" />
                                            </HorizontalStackLayout>
                                        </Border>
                                        <Border Grid.Column="2"
                                    Style="{StaticResource HoverButton}"
                                    BackgroundColor="{DynamicResource AccentColor}"
                                    StrokeShape="RoundRectangle 980"
                                    Padding="16,8" VerticalOptions="Center">
                                            <Border.Behaviors>
                                                <behaviors:PressScaleBehavior />
                                            </Border.Behaviors>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding OpenAddModalCommand}" />
                                            </Border.GestureRecognizers>
                                            <Label Text="+ Add" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource OnAccentColor}" />
                                        </Border>
                                    </Grid>

                                    <ScrollView Orientation="Horizontal"
                                    HorizontalScrollBarVisibility="Never"
                                    Margin="0,12,0,0">
                                        <HorizontalStackLayout Spacing="8" Padding="0,0,16,0">

                                            <!-- ALL -->
                                            <Border Style="{StaticResource HoverButton}"
                                        BackgroundColor="{Binding IsFilterAll, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding IsFilterAll, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="16,7">
                                                <Border.Behaviors>
                                                    <behaviors:PressScaleBehavior />
                                                </Border.Behaviors>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding FilterAllCommand}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="All" FontSize="14"
                                           FontAttributes="{Binding IsFilterAll, Converter={StaticResource BoolToFontAttr}}"
                                           TextColor="{Binding IsFilterAll, Converter={StaticResource BoolToChipText}}" />
                                            </Border>

                                            <!-- TODAY — tap label = today, tap ▾ = pick date -->
                                            <Border Style="{StaticResource HoverButton}"
                                        BackgroundColor="{Binding IsFilterDay, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding IsFilterDay, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,7,6,7">
                                                <HorizontalStackLayout Spacing="0">
                                                    <Label Text="{Binding SelectedDayLabel}" FontSize="14"
                                               FontAttributes="{Binding IsFilterDay, Converter={StaticResource BoolToFontAttr}}"
                                               TextColor="{Binding IsFilterDay, Converter={StaticResource BoolToChipText}}">
                                                        <Label.Behaviors>
                                                            <behaviors:PressScaleBehavior />
                                                        </Label.Behaviors>
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding FilterDayCommand}" />
                                                        </Label.GestureRecognizers>
                                                    </Label>
                                                    <Border BackgroundColor="Transparent" StrokeThickness="0"
                                                Padding="6,0,6,0" VerticalOptions="Center">
                                                        <Border.Behaviors>
                                                            <behaviors:PressScaleBehavior />
                                                        </Border.Behaviors>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding ShowDayPickerCommand}" />
                                                        </Border.GestureRecognizers>
                                                        <Label Text="▾" FontSize="11"
                                                   TextColor="{Binding IsFilterDay, Converter={StaticResource BoolToChipText}}"
                                                   VerticalOptions="Center" />
                                                    </Border>
                                                </HorizontalStackLayout>
                                            </Border>

                                            <!-- THIS WEEK — tap label = current week, tap ▾ = pick week -->
                                            <Border Style="{StaticResource HoverButton}"
                                        BackgroundColor="{Binding IsFilterWeek, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding IsFilterWeek, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,7,6,7">
                                                <HorizontalStackLayout Spacing="0">
                                                    <Label Text="{Binding SelectedWeekLabel}" FontSize="14"
                                               FontAttributes="{Binding IsFilterWeek, Converter={StaticResource BoolToFontAttr}}"
                                               TextColor="{Binding IsFilterWeek, Converter={StaticResource BoolToChipText}}">
                                                        <Label.Behaviors>
                                                            <behaviors:PressScaleBehavior />
                                                        </Label.Behaviors>
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding FilterWeekCommand}" />
                                                        </Label.GestureRecognizers>
                                                    </Label>
                                                    <Border BackgroundColor="Transparent" StrokeThickness="0"
                                                Padding="6,0,6,0" VerticalOptions="Center">
                                                        <Border.Behaviors>
                                                            <behaviors:PressScaleBehavior />
                                                        </Border.Behaviors>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding ShowWeekPickerCommand}" />
                                                        </Border.GestureRecognizers>
                                                        <Label Text="▾" FontSize="11"
                                                   TextColor="{Binding IsFilterWeek, Converter={StaticResource BoolToChipText}}"
                                                   VerticalOptions="Center" />
                                                    </Border>
                                                </HorizontalStackLayout>
                                            </Border>

                                            <!-- THIS MONTH — tap label = current month, tap ▾ = month picker -->
                                            <Border Style="{StaticResource HoverButton}"
                                        BackgroundColor="{Binding IsFilterMonth, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding IsFilterMonth, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,7,6,7">
                                                <HorizontalStackLayout Spacing="0">
                                                    <Label Text="{Binding SelectedMonthLabel}" FontSize="14"
                                               FontAttributes="{Binding IsFilterMonth, Converter={StaticResource BoolToFontAttr}}"
                                               TextColor="{Binding IsFilterMonth, Converter={StaticResource BoolToChipText}}">
                                                        <Label.Behaviors>
                                                            <behaviors:PressScaleBehavior />
                                                        </Label.Behaviors>
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding FilterMonthCommand}" />
                                                        </Label.GestureRecognizers>
                                                    </Label>
                                                    <Border BackgroundColor="Transparent" StrokeThickness="0"
                                                Padding="6,0,6,0" VerticalOptions="Center">
                                                        <Border.Behaviors>
                                                            <behaviors:PressScaleBehavior />
                                                        </Border.Behaviors>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding ShowMonthPickerCommand}" />
                                                        </Border.GestureRecognizers>
                                                        <Label Text="▾" FontSize="11"
                                                   TextColor="{Binding IsFilterMonth, Converter={StaticResource BoolToChipText}}"
                                                   VerticalOptions="Center" />
                                                    </Border>
                                                </HorizontalStackLayout>
                                            </Border>

                                            <!-- THIS YEAR — tap label = current year, tap ▾ = pick year -->
                                            <Border Style="{StaticResource HoverButton}"
                                        BackgroundColor="{Binding IsFilterYear, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding IsFilterYear, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,7,6,7">
                                                <HorizontalStackLayout Spacing="0">
                                                    <Label Text="{Binding SelectedYearLabel}" FontSize="14"
                                               FontAttributes="{Binding IsFilterYear, Converter={StaticResource BoolToFontAttr}}"
                                               TextColor="{Binding IsFilterYear, Converter={StaticResource BoolToChipText}}">
                                                        <Label.Behaviors>
                                                            <behaviors:PressScaleBehavior />
                                                        </Label.Behaviors>
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding FilterYearCommand}" />
                                                        </Label.GestureRecognizers>
                                                    </Label>
                                                    <Border BackgroundColor="Transparent" StrokeThickness="0"
                                                Padding="6,0,6,0" VerticalOptions="Center">
                                                        <Border.Behaviors>
                                                            <behaviors:PressScaleBehavior />
                                                        </Border.Behaviors>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding ShowYearPickerCommand}" />
                                                        </Border.GestureRecognizers>
                                                        <Label Text="▾" FontSize="11"
                                                   TextColor="{Binding IsFilterYear, Converter={StaticResource BoolToChipText}}"
                                                   VerticalOptions="Center" />
                                                    </Border>
                                                </HorizontalStackLayout>
                                            </Border>

                                            <!-- CATEGORY — dropdown only -->
                                            <Border Style="{StaticResource HoverButton}"
                                        BackgroundColor="{Binding IsFilterCategory, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding IsFilterCategory, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="16,7">
                                                <Border.Behaviors>
                                                    <behaviors:PressScaleBehavior />
                                                </Border.Behaviors>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding ShowCategoryPickerCommand}" />
                                                </Border.GestureRecognizers>
                                                <HorizontalStackLayout Spacing="5">
                                                    <Label Text="{Binding SelectedCategoryLabel}" FontSize="14"
                                               FontAttributes="{Binding IsFilterCategory, Converter={StaticResource BoolToFontAttr}}"
                                               TextColor="{Binding IsFilterCategory, Converter={StaticResource BoolToChipText}}" />
                                                    <Label Text="▾" FontSize="11"
                                               TextColor="{Binding IsFilterCategory, Converter={StaticResource BoolToChipText}}"
                                               VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                            </Border>

                                        </HorizontalStackLayout>
                                    </ScrollView>
                                </VerticalStackLayout>
                            </Border>

                            <!-- ── Spending bar chart ───────────────────── -->
                            <Border IsVisible="{Binding ShowFeedBar}"
                                    BackgroundColor="{DynamicResource CardBackground}"
                                    Stroke="{DynamicResource CardBorder}"
                                    StrokeThickness="1" StrokeShape="RoundRectangle 20"
                                    Margin="16,0,16,8" Padding="12,8">
                                <GraphicsView x:Name="BarViewInline"
                                              Drawable="{Binding BarDrawable}"
                                              HeightRequest="284" />
                            </Border>

                            <!-- ── Masonry grid ───────────────────────────────────────── -->
                            <Grid
                    x:Name="MasonryGrid"
                    IsVisible="{Binding IsMasonryView}"
                    ColumnSpacing="10"
                    Padding="14,0,14,100"
                    VerticalOptions="Start" 
                    SizeChanged="MasonryGrid_SizeChanged"/>

                            <!-- List view (alternate to masonry) -->
                            <VerticalStackLayout
                    IsVisible="{Binding IsListView}"
                    Spacing="8"
                    Padding="16,0,16,100"
                    BindableLayout.ItemsSource="{Binding FeedItems}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:FeedCardItem">
                                        <Border BackgroundColor="{DynamicResource CardBackground}"
                                    Stroke="{DynamicResource CardBorder}"
                                    StrokeThickness="1" StrokeShape="RoundRectangle 16"
                                    Padding="12">
                                            <Border.Behaviors>
                                                <behaviors:PressScaleBehavior />
                                            </Border.Behaviors>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=OpenDetailCommand}"
                                        CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                <Image Grid.Column="0" Source="{Binding PhotoPath}"
                                           Aspect="AspectFill" WidthRequest="52" HeightRequest="52"
                                           VerticalOptions="Center"
                                           IsVisible="{Binding ListShowThumbnail}">
                                                    <Image.Clip>
                                                        <RoundRectangleGeometry Rect="0,0,52,52" CornerRadius="12" />
                                                    </Image.Clip>
                                                </Image>
                                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                    <HorizontalStackLayout Spacing="5">
                                                        <Label Text="{Binding CategoryLabel}" FontSize="10"
                                                   FontAttributes="Bold" CharacterSpacing="0.5"
                                                   TextTransform="Uppercase"
                                                   TextColor="{DynamicResource AccentColor}" />
                                                        <Label Text="·" FontSize="10" VerticalOptions="Center"
                                                   IsVisible="{Binding ShowDate}"
                                                   TextColor="{DynamicResource TextSecondary}" />
                                                        <Label Text="{Binding DateFormatted}" FontSize="10"
                                                   VerticalOptions="Center" IsVisible="{Binding ShowDate}"
                                                   TextColor="{DynamicResource TextSecondary}" />
                                                        <Label Text="📷" FontSize="10" VerticalOptions="Center"
                                                   IsVisible="{Binding ListShowPhotoIndicator}" />
                                                    </HorizontalStackLayout>
                                                    <Label Text="{Binding Title}" FontSize="15" FontAttributes="Bold"
                                               LineBreakMode="TailTruncation" IsVisible="{Binding HasTitle}"
                                               TextColor="{DynamicResource TextPrimary}" />
                                                    <Label Text="{Binding GroceryItemCountLabel}" FontSize="15"
                                               FontAttributes="Bold" IsVisible="{Binding IsGroceryGroup}"
                                               TextColor="{DynamicResource TextPrimary}" />
                                                    <Label Text="{Binding Note}" FontSize="12" MaxLines="1"
                                               LineBreakMode="TailTruncation" IsVisible="{Binding ShowNote}"
                                               TextColor="{DynamicResource TextSecondary}" />
                                                </VerticalStackLayout>
                                                <Label Grid.Column="2" Text="{Binding AmountFormatted}"
                                           FontSize="15" FontAttributes="Bold"
                                           IsVisible="{Binding ShowPrice}"
                                           VerticalOptions="Center" HorizontalOptions="End"
                                           TextColor="{DynamicResource TextPrimary}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </ScrollView>
                    
                   
                    
                    <!-- ── Add Expense modal ─────────────────────────────────────────── -->
                </Grid>
            </controls:DrawerHost.BodyContent>

            <controls:DrawerHost.DrawerContent>
                <Grid>

                    <Border BackgroundColor="{DynamicResource CardBackground}"
                    
                    StrokeThickness="0"
                    IsVisible="{Binding IsAddModalVisible}"
                    HorizontalOptions="Fill" VerticalOptions="Fill"
                    >
                        <ScrollView VerticalOptions="Fill">
                            <VerticalStackLayout Padding="18,16,18,18" Spacing="12">

                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="1">
                                        <Label Text="New Entry ✦" FontFamily="DisplayFont"
                                       FontSize="18" TextColor="{DynamicResource TextPrimary}" />
                                        <Label Text="Log what you spent" FontSize="11"
                                       TextColor="{DynamicResource TextSecondary}" />
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1" BackgroundColor="{DynamicResource PageBackground}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 980"
                                    WidthRequest="28" HeightRequest="28" VerticalOptions="Start">
                                        <Border.Behaviors>
                                            <behaviors:PressScaleBehavior />
                                        </Border.Behaviors>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding DismissAddModalCommand}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="✕" FontSize="12" TextColor="{DynamicResource TextSecondary}"
                                       IsVisible="{Binding IsAddModalVisible}"
                    HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                </Grid>

                                <VerticalStackLayout Spacing="5">
                                    <Label Text="Title" FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                                    <Border BackgroundColor="{DynamicResource PageBackground}"
                                    Stroke="{DynamicResource CardBorder}"
                                    StrokeThickness="0.8" StrokeShape="RoundRectangle 10" Padding="12,0">
                                        <Entry Text="{Binding NewTitle}" Placeholder="e.g. Lunch with friends"
                                       PlaceholderColor="#C0C0C5" FontSize="13"
                                       TextColor="{DynamicResource TextPrimary}"
                                       BackgroundColor="Transparent" HeightRequest="40" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="5">
                                    <Label Text="Amount (₱)" FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                                    <Border BackgroundColor="{DynamicResource PageBackground}"
                                    Stroke="{DynamicResource CardBorder}"
                                    StrokeThickness="0.8" StrokeShape="RoundRectangle 10" Padding="12,0">
                                        <Entry Text="{Binding NewAmountText}" Placeholder="0.00"
                                       PlaceholderColor="#C0C0C5" Keyboard="Numeric" FontSize="13"
                                       TextColor="{DynamicResource TextPrimary}"
                                       BackgroundColor="Transparent" HeightRequest="40" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="5">
                                    <Label Text="Category" FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                                    <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start" AlignItems="Center">
                                        <Border BackgroundColor="{Binding NewIsFoodSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding NewIsFoodSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                            <Border.Behaviors>
                                                <behaviors:PressScaleBehavior />
                                            </Border.Behaviors>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SelectNewCategoryCommand}" CommandParameter="Food" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                                <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Food}"
                                           FontSize="14"
                                           TextColor="{Binding NewIsFoodSelected, Converter={StaticResource BoolToIconColor}}" />

                                                <Label Text="Food"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding NewIsFoodSelected, Converter={StaticResource BoolToChipText}}" />

                                            </HorizontalStackLayout>

                                        </Border>
                                        <Border BackgroundColor="{Binding NewIsTransportSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding NewIsTransportSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                            <Border.Behaviors>
                                                <behaviors:PressScaleBehavior />
                                            </Border.Behaviors>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SelectNewCategoryCommand}" CommandParameter="Transport" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">

                                                <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Transport}"
                                           FontSize="14"
                                           TextColor="{Binding NewIsTransportSelected, Converter={StaticResource BoolToIconColor}}"  />

                                                <Label Text="Transport"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding NewIsTransportSelected, Converter={StaticResource BoolToChipText}}" />
                                            </HorizontalStackLayout>
                                        </Border>
                                        <Border BackgroundColor="{Binding NewIsShoppingSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding NewIsShoppingSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                            <Border.Behaviors>
                                                <behaviors:PressScaleBehavior />
                                            </Border.Behaviors>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SelectNewCategoryCommand}" CommandParameter="Shopping" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                                <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Shopping}"
                                           FontSize="14"
                                           TextColor="{Binding NewIsShoppingSelected, Converter={StaticResource BoolToIconColor}}"  />

                                                <Label Text="Shopping"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding NewIsShoppingSelected, Converter={StaticResource BoolToChipText}}" />

                                            </HorizontalStackLayout>
                                        </Border>
                                        <Border BackgroundColor="{Binding NewIsHealthSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding NewIsHealthSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                            <Border.Behaviors>
                                                <behaviors:PressScaleBehavior />
                                            </Border.Behaviors>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SelectNewCategoryCommand}" CommandParameter="Health" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                                <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Health}"
                                           FontSize="14"
                                           TextColor="{Binding NewIsHealthSelected, Converter={StaticResource BoolToIconColor}}"  />

                                                <Label Text="Health"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding NewIsHealthSelected, Converter={StaticResource BoolToChipText}}" />

                                            </HorizontalStackLayout>
                                        </Border>
                                        <Border BackgroundColor="{Binding NewIsFunSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding NewIsFunSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                            <Border.Behaviors>
                                                <behaviors:PressScaleBehavior />
                                            </Border.Behaviors>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SelectNewCategoryCommand}" CommandParameter="Fun" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                                <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Fun}"
                                           FontSize="14"
                                           TextColor="{Binding NewIsFunSelected, Converter={StaticResource BoolToIconColor}}"  />

                                                <Label Text="Fun"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding NewIsFunSelected, Converter={StaticResource BoolToChipText}}" />

                                            </HorizontalStackLayout>
                                        </Border>
                                        <Border BackgroundColor="{Binding NewIsOtherSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding NewIsOtherSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                            <Border.Behaviors>
                                                <behaviors:PressScaleBehavior />
                                            </Border.Behaviors>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SelectNewCategoryCommand}" CommandParameter="Other" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                                <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Default}"
                                           FontSize="14"
                                           TextColor="{Binding NewIsOtherSelected, Converter={StaticResource BoolToIconColor}}"  />

                                                <Label Text="Other"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding NewIsOtherSelected, Converter={StaticResource BoolToChipText}}" />

                                            </HorizontalStackLayout>
                                        </Border>
                                    </FlexLayout>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="5">
                                    <Label Text="Note (optional)" FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                                    <Border BackgroundColor="{DynamicResource PageBackground}"
                                    Stroke="{DynamicResource CardBorder}"
                                    StrokeThickness="0.8" StrokeShape="RoundRectangle 10" Padding="12,0">
                                        <Entry Text="{Binding NewNote}" Placeholder="Any extra details..."
                                       PlaceholderColor="#C0C0C5" FontSize="13"
                                       TextColor="{DynamicResource TextPrimary}"
                                       BackgroundColor="Transparent" HeightRequest="40" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="5">
                                    <Label Text="Date" FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                                    <Border BackgroundColor="{DynamicResource PageBackground}"
                                    Stroke="{DynamicResource CardBorder}"
                                    StrokeThickness="0.8" StrokeShape="RoundRectangle 10" Padding="12,4">
                                        <DatePicker Date="{Binding NewSelectedDate}" Format="MMMM dd, yyyy"
                                            FontSize="13" TextColor="{DynamicResource TextPrimary}"
                                            BackgroundColor="Transparent" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="5">
                                    <Label Text="Photo (optional)" FontSize="11" FontAttributes="Bold"
                                       TextColor="{DynamicResource TextPrimary}" />

                                    <!-- Picker area — collapses once a photo is chosen -->
                                    <VerticalStackLayout IsVisible="{Binding NewHasPhoto, Converter={StaticResource InverseBool}}"
                                                     Spacing="8">

                                        <!-- ── 2×2 source grid ── -->
                                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                                          ColumnSpacing="8" RowSpacing="8">

                                            <!-- From Files -->
                                            <Border Grid.Row="0" Grid.Column="0"
                                                BackgroundColor="{DynamicResource PageBackground}"
                                                Stroke="{DynamicResource CardBorder}"
                                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                                Padding="0,14" Style="{StaticResource HoverButton}">
                                                <Border.Behaviors>
                                                    <behaviors:PressScaleBehavior />
                                                </Border.Behaviors>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding PickNewPhotoCommand}" />
                                                </Border.GestureRecognizers>
                                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                                    <Label Style="{StaticResource PhosphorIcon}"
                                                       Text="{x:Static ph:PhosphorIcons.FolderOpen}"
                                                       FontSize="18" HorizontalOptions="Center"
                                                       TextColor="{DynamicResource AccentColor}" />
                                                    <Label Text="From Files" FontSize="11"
                                                       HorizontalOptions="Center"
                                                       TextColor="{DynamicResource TextSecondary}" />
                                                </VerticalStackLayout>
                                            </Border>

                                            <!-- Unsplash -->
                                            <Border Grid.Row="0" Grid.Column="1"
                                                BackgroundColor="{DynamicResource PageBackground}"
                                                Stroke="{DynamicResource CardBorder}"
                                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                                Padding="0,14" Style="{StaticResource HoverButton}">
                                                <Border.Behaviors>
                                                    <behaviors:PressScaleBehavior />
                                                </Border.Behaviors>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding ToggleUnsplashPanelCommand}" />
                                                </Border.GestureRecognizers>
                                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                                    <Label Style="{StaticResource PhosphorIcon}"
                                                       Text="{x:Static ph:PhosphorIcons.Globe}"
                                                       FontSize="18" HorizontalOptions="Center"
                                                       TextColor="{DynamicResource AccentColor}" />
                                                    <Label Text="Unsplash" FontSize="11"
                                                       HorizontalOptions="Center"
                                                       TextColor="{DynamicResource TextSecondary}" />
                                                </VerticalStackLayout>
                                            </Border>

                                            <!-- Paste Image -->
                                            <Border Grid.Row="1" Grid.Column="0"
                                                BackgroundColor="{DynamicResource PageBackground}"
                                                Stroke="{DynamicResource CardBorder}"
                                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                                Padding="0,14" Style="{StaticResource HoverButton}">
                                                <Border.Behaviors>
                                                    <behaviors:PressScaleBehavior />
                                                </Border.Behaviors>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding PasteImageCommand}" />
                                                </Border.GestureRecognizers>
                                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                                    <Label Style="{StaticResource PhosphorIcon}"
                                                       Text="{x:Static ph:PhosphorIcons.ClipboardText}"
                                                       FontSize="18" HorizontalOptions="Center"
                                                       TextColor="{DynamicResource AccentColor}" />
                                                    <Label Text="Paste Image" FontSize="11"
                                                       HorizontalOptions="Center"
                                                       TextColor="{DynamicResource TextSecondary}" />
                                                </VerticalStackLayout>
                                            </Border>

                                            <!-- Paste URL -->
                                            <Border Grid.Row="1" Grid.Column="1"
                                                BackgroundColor="{DynamicResource PageBackground}"
                                                Stroke="{DynamicResource CardBorder}"
                                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                                Padding="0,14" Style="{StaticResource HoverButton}">
                                                <Border.Behaviors>
                                                    <behaviors:PressScaleBehavior />
                                                </Border.Behaviors>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding TogglePasteUrlRowCommand}" />
                                                </Border.GestureRecognizers>
                                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                                    <Label Style="{StaticResource PhosphorIcon}"
                                                       Text="{x:Static ph:PhosphorIcons.Link}"
                                                       FontSize="18" HorizontalOptions="Center"
                                                       TextColor="{DynamicResource AccentColor}" />
                                                    <Label Text="Paste URL" FontSize="11"
                                                       HorizontalOptions="Center"
                                                       TextColor="{DynamicResource TextSecondary}" />
                                                </VerticalStackLayout>
                                            </Border>
                                        </Grid>

                                        <!-- ── Unsplash in-drawer panel (Add) ── -->
                                        <VerticalStackLayout IsVisible="{Binding IsUnsplashPanelOpen}"
                                                         Spacing="8">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <Border Grid.Column="0"
                                                    BackgroundColor="{DynamicResource PageBackground}"
                                                    Stroke="{DynamicResource CardBorder}"
                                                    StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                                    Padding="12,0">
                                                    <Entry Text="{Binding UnsplashQuery}"
                                                       Placeholder="Search Unsplash…"
                                                       PlaceholderColor="#C0C0C5" FontSize="13"
                                                       TextColor="{DynamicResource TextPrimary}"
                                                       BackgroundColor="Transparent" HeightRequest="40"
                                                       ReturnCommand="{Binding SearchUnsplashCommand}" />
                                                </Border>
                                                <Border Grid.Column="1"
                                                    BackgroundColor="{DynamicResource AccentColor}"
                                                    StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                                    Padding="14,0" Style="{StaticResource HoverButton}">
                                                    <Border.Behaviors>
                                                        <behaviors:PressScaleBehavior />
                                                    </Border.Behaviors>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding SearchUnsplashCommand}" />
                                                    </Border.GestureRecognizers>
                                                    <Label Text="Search" FontSize="13" FontAttributes="Bold"
                                                       TextColor="{DynamicResource OnAccentColor}"
                                                       VerticalOptions="Center" />
                                                </Border>
                                            </Grid>
                                            <ActivityIndicator IsRunning="{Binding IsUnsplashLoading}"
                                                           IsVisible="{Binding IsUnsplashLoading}"
                                                           Color="{DynamicResource AccentColor}"
                                                           HorizontalOptions="Center" />
                                            <!-- Thumbnail grid.
                                             FlexLayout+BindableLayout avoids nested-ScrollView height issues
                                             that CollectionView causes inside the drawer's ScrollView.
                                             No x:DataType on the DataTemplate: runtime bindings let us
                                             walk ContentPage.BindingContext to reach the ViewModel command. -->
                                            <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start"
                                                    BindableLayout.ItemsSource="{Binding UnsplashResults}">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border WidthRequest="106" HeightRequest="80"
                                                            Margin="0,0,4,4"
                                                            StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                                            Style="{StaticResource HoverButton}">
                                                            <Border.Behaviors>
                                                                <behaviors:PressScaleBehavior />
                                                            </Border.Behaviors>
                                                            <Border.GestureRecognizers>
                                                                <TapGestureRecognizer
                                                                Command="{Binding BindingContext.SelectUnsplashPhotoCommand,
                                                                          Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                                CommandParameter="{Binding BindingContext,
                                                                          Source={RelativeSource AncestorType={x:Type Border}}}" />
                                                            </Border.GestureRecognizers>
                                                            <Image Source="{Binding ThumbUrl}" Aspect="AspectFill">
                                                                <Image.Clip>
                                                                    <RoundRectangleGeometry Rect="0,0,106,80"
                                                                                        CornerRadius="8" />
                                                                </Image.Clip>
                                                            </Image>
                                                        </Border>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </FlexLayout>
                                            <Border IsVisible="{Binding HasMoreUnsplashPages}"
                                                BackgroundColor="{DynamicResource PageBackground}"
                                                Stroke="{DynamicResource AccentColor}"
                                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                                Padding="0,10" Style="{StaticResource HoverButton}">
                                                <Border.Behaviors>
                                                    <behaviors:PressScaleBehavior />
                                                </Border.Behaviors>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding LoadMoreUnsplashCommand}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="Load more" FontSize="12"
                                                   TextColor="{DynamicResource AccentColor}"
                                                   HorizontalOptions="Center" />
                                            </Border>
                                        </VerticalStackLayout>

                                        <!-- ── Paste URL row (Add) ── -->
                                        <Grid IsVisible="{Binding IsPasteUrlRowOpen}"
                                          ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <Border Grid.Column="0"
                                                BackgroundColor="{DynamicResource PageBackground}"
                                                Stroke="{DynamicResource CardBorder}"
                                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                                Padding="12,0">
                                                <Entry Text="{Binding PasteUrlText}"
                                                   Placeholder="Paste image URL…"
                                                   PlaceholderColor="#C0C0C5" FontSize="13"
                                                   TextColor="{DynamicResource TextPrimary}"
                                                   BackgroundColor="Transparent" HeightRequest="40" />
                                            </Border>
                                            <Border Grid.Column="1"
                                                BackgroundColor="{DynamicResource AccentColor}"
                                                StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                                Padding="14,0" Style="{StaticResource HoverButton}">
                                                <Border.Behaviors>
                                                    <behaviors:PressScaleBehavior />
                                                </Border.Behaviors>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding PasteUrlCommand}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="Download" FontSize="13" FontAttributes="Bold"
                                                   TextColor="{DynamicResource OnAccentColor}"
                                                   VerticalOptions="Center" />
                                            </Border>
                                        </Grid>

                                    </VerticalStackLayout>

                                    <!-- ── Preview strip (unchanged) ── -->
                                    <VerticalStackLayout IsVisible="{Binding NewHasPhoto}" Spacing="0">
                                        <Border BackgroundColor="{DynamicResource PageBackground}"
                                            Stroke="{DynamicResource CardBorder}"
                                            StrokeThickness="0.8" StrokeShape="RoundRectangle 10" Padding="0">
                                            <Grid RowDefinitions="Auto,Auto">
                                                <Image Grid.Row="0" Source="{Binding NewPhotoPath}"
                                                   Aspect="AspectFill" HeightRequest="110">
                                                    <Image.Clip>
                                                        <RoundRectangleGeometry Rect="0,0,1000,110"
                                                                            CornerRadius="10,10,0,0" />
                                                    </Image.Clip>
                                                </Image>
                                                <Border Grid.Row="1" BackgroundColor="#1Fff3b30"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 0,0,10,10" Padding="0,7">
                                                    <Border.Behaviors>
                                                        <behaviors:PressScaleBehavior />
                                                    </Border.Behaviors>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding RemoveNewPhotoCommand}" />
                                                    </Border.GestureRecognizers>
                                                    <Label Text="✕ Remove photo" FontSize="12"
                                                       TextColor="#ff3b30" HorizontalOptions="Center" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>

                                <Border BackgroundColor="{DynamicResource AccentColor}" StrokeThickness="0"
                                Style="{StaticResource HoverButton}"
                                StrokeShape="RoundRectangle 980" Padding="0,12">
                                    <Border.Behaviors>
                                        <behaviors:PressScaleBehavior />
                                    </Border.Behaviors>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SaveNewExpenseCommand}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Save Entry" FontSize="13" FontAttributes="Bold"
                                   TextColor="{DynamicResource OnAccentColor}" HorizontalOptions="Center" />
                                </Border>

                            </VerticalStackLayout>
                        </ScrollView>
                    </Border>

                    <Border BackgroundColor="{DynamicResource CardBackground}"
                    
                    StrokeThickness="0"
                    IsVisible="{Binding IsEditModalVisible}"
                    HorizontalOptions="Fill" VerticalOptions="Fill"
                    >
                        <ScrollView>
                            <VerticalStackLayout Padding="18,16,18,18" Spacing="12">

                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="1">
                                        <Label Text="Edit Entry ✦" FontFamily="DisplayFont"
                                       FontSize="18" TextColor="{DynamicResource TextPrimary}" />
                                        <Label Text="Update your expense" FontSize="11"
                                       TextColor="{DynamicResource TextSecondary}" />
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1" BackgroundColor="{DynamicResource PageBackground}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 980"
                                    WidthRequest="28" HeightRequest="28" VerticalOptions="Start">
                                        <Border.Behaviors>
                                            <behaviors:PressScaleBehavior />
                                        </Border.Behaviors>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding DismissEditModalCommand}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="✕" FontSize="12" TextColor="{DynamicResource TextSecondary}"
                                       IsVisible="{Binding IsEditModalVisible}"
                    HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                </Grid>

                                <VerticalStackLayout Spacing="5">
                                    <Label Text="Title" FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                                    <Border BackgroundColor="{DynamicResource PageBackground}"
                                    Stroke="{DynamicResource CardBorder}"
                                    StrokeThickness="0.8" StrokeShape="RoundRectangle 10" Padding="12,0">
                                        <Entry Text="{Binding EditTitle}" Placeholder="e.g. Lunch with friends"
                                       PlaceholderColor="#C0C0C5" FontSize="13"
                                       TextColor="{DynamicResource TextPrimary}"
                                       BackgroundColor="Transparent" HeightRequest="40" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="5">
                                    <Label Text="Amount (₱)" FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                                    <Border BackgroundColor="{DynamicResource PageBackground}"
                                    Stroke="{DynamicResource CardBorder}"
                                    StrokeThickness="0.8" StrokeShape="RoundRectangle 10" Padding="12,0">
                                        <Entry Text="{Binding EditAmountText}" Placeholder="0.00"
                                       PlaceholderColor="#C0C0C5" Keyboard="Numeric" FontSize="13"
                                       TextColor="{DynamicResource TextPrimary}"
                                       BackgroundColor="Transparent" HeightRequest="40" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="5">
                                    <Label Text="Category" FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                                    <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start" AlignItems="Center">
                                        <Border BackgroundColor="{Binding EditIsFoodSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding EditIsFoodSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                            <Border.Behaviors>
                                                <behaviors:PressScaleBehavior />
                                            </Border.Behaviors>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SelectEditCategoryCommand}" CommandParameter="Food" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                                <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Food}"
                                           FontSize="14"
                                           TextColor="{Binding EditIsFoodSelected, Converter={StaticResource BoolToIconColor}}"  />

                                                <Label Text="Food"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding EditIsFoodSelected, Converter={StaticResource BoolToChipText}}" />

                                            </HorizontalStackLayout>
                                        </Border>
                                        <Border BackgroundColor="{Binding EditIsTransportSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding EditIsTransportSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                            <Border.Behaviors>
                                                <behaviors:PressScaleBehavior />
                                            </Border.Behaviors>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SelectEditCategoryCommand}" CommandParameter="Transport" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                                <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Transport}"
                                           FontSize="14"
                                           TextColor="{Binding EditIsTransportSelected, Converter={StaticResource BoolToIconColor}}"  />
                                                <Label Text="Transport"
                                            FontSize="12"
                                            VerticalOptions="Center"
                                            TextColor="{Binding EditIsTransportSelected, Converter={StaticResource BoolToChipText}}" />
                                            </HorizontalStackLayout>
                                        </Border>
                                        <Border BackgroundColor="{Binding EditIsShoppingSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding EditIsShoppingSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                            <Border.Behaviors>
                                                <behaviors:PressScaleBehavior />
                                            </Border.Behaviors>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SelectEditCategoryCommand}" CommandParameter="Shopping" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                                <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Shopping}"
                                           FontSize="14"
                                           TextColor="{Binding EditIsShoppingSelected, Converter={StaticResource BoolToIconColor}}"  />

                                           <Label Text="Shopping"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding EditIsShoppingSelected, Converter={StaticResource BoolToChipText}}" />

                                            </HorizontalStackLayout>
                                        </Border>
                                        <Border BackgroundColor="{Binding EditIsHealthSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding EditIsHealthSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                            <Border.Behaviors>
                                                <behaviors:PressScaleBehavior />
                                            </Border.Behaviors>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SelectEditCategoryCommand}" CommandParameter="Health" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                                <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Health}"
                                           FontSize="14"
                                           TextColor="{Binding EditIsHealthSelected, Converter={StaticResource BoolToIconColor}}"  />

                                                <Label Text="Health"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding EditIsHealthSelected, Converter={StaticResource BoolToChipText}}" />

                                            </HorizontalStackLayout>
                                        </Border>
                                        <Border BackgroundColor="{Binding EditIsFunSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding EditIsFunSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                            <Border.Behaviors>
                                                <behaviors:PressScaleBehavior />
                                            </Border.Behaviors>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SelectEditCategoryCommand}" CommandParameter="Fun" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                                                <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Fun}"
                                           FontSize="14"
                                           TextColor="{Binding EditIsFunSelected, Converter={StaticResource BoolToIconColor}}"  />

                                                <Label Text="Fun"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding EditIsFunSelected, Converter={StaticResource BoolToChipText}}" />

                                            </HorizontalStackLayout>
                                        </Border>
                                        <Border BackgroundColor="{Binding EditIsOtherSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding EditIsOtherSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                            <Border.Behaviors>
                                                <behaviors:PressScaleBehavior />
                                            </Border.Behaviors>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SelectEditCategoryCommand}" CommandParameter="Other" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                                <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Default}"
                                           FontSize="14"
                                           TextColor="{Binding EditIsOtherSelected, Converter={StaticResource BoolToIconColor}}"  />

                                                <Label Text="Other"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding EditIsOtherSelected, Converter={StaticResource BoolToChipText}}" />

                                            </HorizontalStackLayout>
                                        </Border>
                                    </FlexLayout>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="5">
                                    <Label Text="Note (optional)" FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                                    <Border BackgroundColor="{DynamicResource PageBackground}"
                                    Stroke="{DynamicResource CardBorder}"
                                    StrokeThickness="0.8" StrokeShape="RoundRectangle 10" Padding="12,0">
                                        <Entry Text="{Binding EditNote}" Placeholder="Any extra details..."
                                       PlaceholderColor="#C0C0C5" FontSize="13"
                                       TextColor="{DynamicResource TextPrimary}"
                                       BackgroundColor="Transparent" HeightRequest="40" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="5">
                                    <Label Text="Date" FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                                    <Border BackgroundColor="{DynamicResource PageBackground}"
                                    Stroke="{DynamicResource CardBorder}"
                                    StrokeThickness="0.8" StrokeShape="RoundRectangle 10" Padding="12,4">
                                        <DatePicker Date="{Binding EditSelectedDate}" Format="MMMM dd, yyyy"
                                            FontSize="13" TextColor="{DynamicResource TextPrimary}"
                                            BackgroundColor="Transparent" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="5">
                                    <Label Text="Photo (optional)" FontSize="11" FontAttributes="Bold"
                                       TextColor="{DynamicResource TextPrimary}" />

                                    <!-- Picker area — collapses once a photo is chosen -->
                                    <VerticalStackLayout IsVisible="{Binding EditHasPhoto, Converter={StaticResource InverseBool}}"
                                                     Spacing="8">

                                        <!-- ── 2×2 source grid ── -->
                                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                                          ColumnSpacing="8" RowSpacing="8">

                                            <!-- From Files -->
                                            <Border Grid.Row="0" Grid.Column="0"
                                                BackgroundColor="{DynamicResource PageBackground}"
                                                Stroke="{DynamicResource CardBorder}"
                                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                                Padding="0,14" Style="{StaticResource HoverButton}">
                                                <Border.Behaviors>
                                                    <behaviors:PressScaleBehavior />
                                                </Border.Behaviors>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding PickEditPhotoCommand}" />
                                                </Border.GestureRecognizers>
                                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                                    <Label Style="{StaticResource PhosphorIcon}"
                                                       Text="{x:Static ph:PhosphorIcons.FolderOpen}"
                                                       FontSize="18" HorizontalOptions="Center"
                                                       TextColor="{DynamicResource AccentColor}" />
                                                    <Label Text="From Files" FontSize="11"
                                                       HorizontalOptions="Center"
                                                       TextColor="{DynamicResource TextSecondary}" />
                                                </VerticalStackLayout>
                                            </Border>

                                            <!-- Unsplash -->
                                            <Border Grid.Row="0" Grid.Column="1"
                                                BackgroundColor="{DynamicResource PageBackground}"
                                                Stroke="{DynamicResource CardBorder}"
                                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                                Padding="0,14" Style="{StaticResource HoverButton}">
                                                <Border.Behaviors>
                                                    <behaviors:PressScaleBehavior />
                                                </Border.Behaviors>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding ToggleUnsplashPanelCommand}" />
                                                </Border.GestureRecognizers>
                                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                                    <Label Style="{StaticResource PhosphorIcon}"
                                                       Text="{x:Static ph:PhosphorIcons.Globe}"
                                                       FontSize="18" HorizontalOptions="Center"
                                                       TextColor="{DynamicResource AccentColor}" />
                                                    <Label Text="Unsplash" FontSize="11"
                                                       HorizontalOptions="Center"
                                                       TextColor="{DynamicResource TextSecondary}" />
                                                </VerticalStackLayout>
                                            </Border>

                                            <!-- Paste Image -->
                                            <Border Grid.Row="1" Grid.Column="0"
                                                BackgroundColor="{DynamicResource PageBackground}"
                                                Stroke="{DynamicResource CardBorder}"
                                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                                Padding="0,14" Style="{StaticResource HoverButton}">
                                                <Border.Behaviors>
                                                    <behaviors:PressScaleBehavior />
                                                </Border.Behaviors>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding PasteEditImageCommand}" />
                                                </Border.GestureRecognizers>
                                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                                    <Label Style="{StaticResource PhosphorIcon}"
                                                       Text="{x:Static ph:PhosphorIcons.ClipboardText}"
                                                       FontSize="18" HorizontalOptions="Center"
                                                       TextColor="{DynamicResource AccentColor}" />
                                                    <Label Text="Paste Image" FontSize="11"
                                                       HorizontalOptions="Center"
                                                       TextColor="{DynamicResource TextSecondary}" />
                                                </VerticalStackLayout>
                                            </Border>

                                            <!-- Paste URL -->
                                            <Border Grid.Row="1" Grid.Column="1"
                                                BackgroundColor="{DynamicResource PageBackground}"
                                                Stroke="{DynamicResource CardBorder}"
                                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                                Padding="0,14" Style="{StaticResource HoverButton}">
                                                <Border.Behaviors>
                                                    <behaviors:PressScaleBehavior />
                                                </Border.Behaviors>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding ToggleEditPasteUrlRowCommand}" />
                                                </Border.GestureRecognizers>
                                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                                    <Label Style="{StaticResource PhosphorIcon}"
                                                       Text="{x:Static ph:PhosphorIcons.Link}"
                                                       FontSize="18" HorizontalOptions="Center"
                                                       TextColor="{DynamicResource AccentColor}" />
                                                    <Label Text="Paste URL" FontSize="11"
                                                       HorizontalOptions="Center"
                                                       TextColor="{DynamicResource TextSecondary}" />
                                                </VerticalStackLayout>
                                            </Border>
                                        </Grid>

                                        <!-- ── Unsplash in-drawer panel (Edit) ── -->
                                        <VerticalStackLayout IsVisible="{Binding IsUnsplashPanelOpen}"
                                                         Spacing="8">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <Border Grid.Column="0"
                                                    BackgroundColor="{DynamicResource PageBackground}"
                                                    Stroke="{DynamicResource CardBorder}"
                                                    StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                                    Padding="12,0">
                                                    <Entry Text="{Binding UnsplashQuery}"
                                                       Placeholder="Search Unsplash…"
                                                       PlaceholderColor="#C0C0C5" FontSize="13"
                                                       TextColor="{DynamicResource TextPrimary}"
                                                       BackgroundColor="Transparent" HeightRequest="40"
                                                       ReturnCommand="{Binding SearchUnsplashCommand}" />
                                                </Border>
                                                <Border Grid.Column="1"
                                                    BackgroundColor="{DynamicResource AccentColor}"
                                                    StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                                    Padding="14,0" Style="{StaticResource HoverButton}">
                                                    <Border.Behaviors>
                                                        <behaviors:PressScaleBehavior />
                                                    </Border.Behaviors>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding SearchUnsplashCommand}" />
                                                    </Border.GestureRecognizers>
                                                    <Label Text="Search" FontSize="13" FontAttributes="Bold"
                                                       TextColor="{DynamicResource OnAccentColor}"
                                                       VerticalOptions="Center" />
                                                </Border>
                                            </Grid>
                                            <ActivityIndicator IsRunning="{Binding IsUnsplashLoading}"
                                                           IsVisible="{Binding IsUnsplashLoading}"
                                                           Color="{DynamicResource AccentColor}"
                                                           HorizontalOptions="Center" />
                                            <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start"
                                                    BindableLayout.ItemsSource="{Binding UnsplashResults}">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border WidthRequest="106" HeightRequest="80"
                                                            Margin="0,0,4,4"
                                                            StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                                            Style="{StaticResource HoverButton}">
                                                            <Border.Behaviors>
                                                                <behaviors:PressScaleBehavior />
                                                            </Border.Behaviors>
                                                            <Border.GestureRecognizers>
                                                                <TapGestureRecognizer
                                                                Command="{Binding BindingContext.SelectUnsplashPhotoCommand,
                                                                          Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                                CommandParameter="{Binding BindingContext,
                                                                          Source={RelativeSource AncestorType={x:Type Border}}}" />
                                                            </Border.GestureRecognizers>
                                                            <Image Source="{Binding ThumbUrl}" Aspect="AspectFill">
                                                                <Image.Clip>
                                                                    <RoundRectangleGeometry Rect="0,0,106,80"
                                                                                        CornerRadius="8" />
                                                                </Image.Clip>
                                                            </Image>
                                                        </Border>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </FlexLayout>
                                            <Border IsVisible="{Binding HasMoreUnsplashPages}"
                                                BackgroundColor="{DynamicResource PageBackground}"
                                                Stroke="{DynamicResource AccentColor}"
                                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                                Padding="0,10" Style="{StaticResource HoverButton}">
                                                <Border.Behaviors>
                                                    <behaviors:PressScaleBehavior />
                                                </Border.Behaviors>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding LoadMoreUnsplashCommand}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="Load more" FontSize="12"
                                                   TextColor="{DynamicResource AccentColor}"
                                                   HorizontalOptions="Center" />
                                            </Border>
                                        </VerticalStackLayout>

                                        <!-- ── Paste URL row (Edit) ── -->
                                        <Grid IsVisible="{Binding IsEditPasteUrlRowOpen}"
                                          ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <Border Grid.Column="0"
                                                BackgroundColor="{DynamicResource PageBackground}"
                                                Stroke="{DynamicResource CardBorder}"
                                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                                Padding="12,0">
                                                <Entry Text="{Binding EditPasteUrlText}"
                                                   Placeholder="Paste image URL…"
                                                   PlaceholderColor="#C0C0C5" FontSize="13"
                                                   TextColor="{DynamicResource TextPrimary}"
                                                   BackgroundColor="Transparent" HeightRequest="40" />
                                            </Border>
                                            <Border Grid.Column="1"
                                                BackgroundColor="{DynamicResource AccentColor}"
                                                StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                                Padding="14,0" Style="{StaticResource HoverButton}">
                                                <Border.Behaviors>
                                                    <behaviors:PressScaleBehavior />
                                                </Border.Behaviors>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding PasteEditUrlCommand}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="Download" FontSize="13" FontAttributes="Bold"
                                                   TextColor="{DynamicResource OnAccentColor}"
                                                   VerticalOptions="Center" />
                                            </Border>
                                        </Grid>

                                    </VerticalStackLayout>

                                    <!-- ── Preview strip (unchanged) ── -->
                                    <VerticalStackLayout IsVisible="{Binding EditHasPhoto}" Spacing="0">
                                        <Border BackgroundColor="{DynamicResource PageBackground}"
                                            Stroke="{DynamicResource CardBorder}"
                                            StrokeThickness="0.8" StrokeShape="RoundRectangle 10" Padding="0">
                                            <Grid RowDefinitions="Auto,Auto">
                                                <Image Grid.Row="0" Source="{Binding EditPhotoPath}"
                                                   Aspect="AspectFill" HeightRequest="110">
                                                    <Image.Clip>
                                                        <RoundRectangleGeometry Rect="0,0,1000,110"
                                                                            CornerRadius="10,10,0,0" />
                                                    </Image.Clip>
                                                </Image>
                                                <Border Grid.Row="1" BackgroundColor="#1Fff3b30"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 0,0,10,10" Padding="0,7">
                                                    <Border.Behaviors>
                                                        <behaviors:PressScaleBehavior />
                                                    </Border.Behaviors>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding RemoveEditPhotoCommand}" />
                                                    </Border.GestureRecognizers>
                                                    <Label Text="✕ Remove photo" FontSize="12"
                                                       TextColor="#ff3b30" HorizontalOptions="Center" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>

                                <Border BackgroundColor="{DynamicResource AccentColor}" StrokeThickness="0"
                                Style="{StaticResource HoverButton}"
                                StrokeShape="RoundRectangle 980" Padding="0,12">
                                    <Border.Behaviors>
                                        <behaviors:PressScaleBehavior />
                                    </Border.Behaviors>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SaveEditExpenseCommand}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Update Entry" FontSize="13" FontAttributes="Bold"
                                   TextColor="{DynamicResource OnAccentColor}" HorizontalOptions="Center" />
                                </Border>

                            </VerticalStackLayout>
                        </ScrollView>
                    </Border>

                </Grid>
            </controls:DrawerHost.DrawerContent>

        </controls:DrawerHost>

        <Grid IsVisible="{Binding IsMonthPickerVisible}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding DismissMonthPickerCommand}" />
            </Grid.GestureRecognizers>
            <controls:BlurOverlay />
            <Border BackgroundColor="{DynamicResource CardBackground}"
                    Style="{StaticResource ModalCard}"
                    StrokeShape="RoundRectangle 20"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    MaximumWidthRequest="340"
                    Margin="20,0" Padding="24,24">
                <VerticalStackLayout Spacing="20">

                    <Label Text="Select month" FontSize="17" FontAttributes="Bold"
                           TextColor="{DynamicResource TextPrimary}" />

                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0"
                                BackgroundColor="{DynamicResource PageBackground}"
                                StrokeThickness="0" StrokeShape="RoundRectangle 980"
                                WidthRequest="36" HeightRequest="36">
                            <Border.Behaviors>
                                <behaviors:PressScaleBehavior />
                            </Border.Behaviors>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PreviousYearCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="‹" FontSize="20" TextColor="{DynamicResource TextPrimary}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Column="1" Text="{Binding PickerYear}"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border Grid.Column="2"
                                BackgroundColor="{DynamicResource PageBackground}"
                                StrokeThickness="0" StrokeShape="RoundRectangle 980"
                                WidthRequest="36" HeightRequest="36">
                            <Border.Behaviors>
                                <behaviors:PressScaleBehavior />
                            </Border.Behaviors>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding NextYearCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="›" FontSize="20" TextColor="{DynamicResource TextPrimary}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <CollectionView ItemsSource="{Binding MonthOptions}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="4"
                                             HorizontalItemSpacing="8" VerticalItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:MonthOption">
                                <Border
                                    BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToChipBg}}"
                                    Stroke="{Binding IsSelected, Converter={StaticResource BoolToChipBorder}}"
                                    StrokeShape="RoundRectangle 12" StrokeThickness="0.8"
                                    Padding="0,10" HeightRequest="44">
                                    <Border.Behaviors>
                                        <behaviors:PressScaleBehavior />
                                    </Border.Behaviors>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=SelectMonthCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="{Binding ShortName}" FontSize="13"
                                           FontAttributes="{Binding IsSelected, Converter={StaticResource BoolToFontAttr}}"
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           TextColor="{Binding IsSelected, Converter={StaticResource BoolToChipText}}" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ── Category picker overlay ───────────────────────────────────── -->
        <Grid IsVisible="{Binding IsCategoryPickerVisible}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding DismissCategoryPickerCommand}" />
            </Grid.GestureRecognizers>
            <controls:BlurOverlay />
            <Border BackgroundColor="{DynamicResource CardBackground}"
                    Style="{StaticResource ModalCard}"
                    StrokeShape="RoundRectangle 20"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    MaximumWidthRequest="320"
                    Margin="20,0" Padding="24,24">
                <VerticalStackLayout Spacing="16">

                    <Label Text="Filter by category" FontSize="17" FontAttributes="Bold"
                           TextColor="{DynamicResource TextPrimary}" />

                    <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start" AlignItems="Center">

                        <!-- Food -->
                        <Border Style="{StaticResource HoverButton}"
            BackgroundColor="{DynamicResource PageBackground}"
            Stroke="{DynamicResource CardBorder}"
            StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
            Padding="14,8" Margin="0,0,8,8">
                            <Border.Behaviors>
                                <behaviors:PressScaleBehavior />
                            </Border.Behaviors>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectCategoryFilterCommand}"
                                  CommandParameter="Food" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Label Style="{StaticResource PhosphorIcon}"
                   Text="{x:Static ph:PhosphorIcons.Food}"
                   FontSize="14"
                   TextColor="{DynamicResource AccentColor}" />
                                <Label Text="Food" FontSize="12" VerticalOptions="Center"
                   TextColor="{DynamicResource TextPrimary}" />
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Transport -->
                        <Border Style="{StaticResource HoverButton}"
            BackgroundColor="{DynamicResource PageBackground}"
            Stroke="{DynamicResource CardBorder}"
            StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
            Padding="14,8" Margin="0,0,8,8">
                            <Border.Behaviors>
                                <behaviors:PressScaleBehavior />
                            </Border.Behaviors>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectCategoryFilterCommand}"
                                  CommandParameter="Transport" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Label Style="{StaticResource PhosphorIcon}"
                   Text="{x:Static ph:PhosphorIcons.Transport}"
                   FontSize="14"
                   TextColor="{DynamicResource AccentColor}" />
                                <Label Text="Transport" FontSize="12" VerticalOptions="Center"
                   TextColor="{DynamicResource TextPrimary}" />
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Shopping -->
                        <Border Style="{StaticResource HoverButton}"
            BackgroundColor="{DynamicResource PageBackground}"
            Stroke="{DynamicResource CardBorder}"
            StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
            Padding="14,8" Margin="0,0,8,8">
                            <Border.Behaviors>
                                <behaviors:PressScaleBehavior />
                            </Border.Behaviors>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectCategoryFilterCommand}"
                                  CommandParameter="Shopping" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Label Style="{StaticResource PhosphorIcon}"
                   Text="{x:Static ph:PhosphorIcons.Shopping}"
                   FontSize="14"
                   TextColor="{DynamicResource AccentColor}" />
                                <Label Text="Shopping" FontSize="12" VerticalOptions="Center"
                   TextColor="{DynamicResource TextPrimary}" />
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Health -->
                        <Border Style="{StaticResource HoverButton}"
            BackgroundColor="{DynamicResource PageBackground}"
            Stroke="{DynamicResource CardBorder}"
            StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
            Padding="14,8" Margin="0,0,8,8">
                            <Border.Behaviors>
                                <behaviors:PressScaleBehavior />
                            </Border.Behaviors>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectCategoryFilterCommand}"
                                  CommandParameter="Health" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Label Style="{StaticResource PhosphorIcon}"
                   Text="{x:Static ph:PhosphorIcons.Health}"
                   FontSize="14"
                   TextColor="{DynamicResource AccentColor}" />
                                <Label Text="Health" FontSize="12" VerticalOptions="Center"
                   TextColor="{DynamicResource TextPrimary}" />
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Fun -->
                        <Border Style="{StaticResource HoverButton}"
            BackgroundColor="{DynamicResource PageBackground}"
            Stroke="{DynamicResource CardBorder}"
            StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
            Padding="14,8" Margin="0,0,8,8">
                            <Border.Behaviors>
                                <behaviors:PressScaleBehavior />
                            </Border.Behaviors>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectCategoryFilterCommand}"
                                  CommandParameter="Fun" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Label Style="{StaticResource PhosphorIcon}"
                   Text="{x:Static ph:PhosphorIcons.Fun}"
                   FontSize="14"
                   TextColor="{DynamicResource AccentColor}" />
                                <Label Text="Fun" FontSize="12" VerticalOptions="Center"
                   TextColor="{DynamicResource TextPrimary}" />
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Other -->
                        <Border Style="{StaticResource HoverButton}"
            BackgroundColor="{DynamicResource PageBackground}"
            Stroke="{DynamicResource CardBorder}"
            StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
            Padding="14,8" Margin="0,0,8,8">
                            <Border.Behaviors>
                                <behaviors:PressScaleBehavior />
                            </Border.Behaviors>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectCategoryFilterCommand}"
                                  CommandParameter="Other" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Label Style="{StaticResource PhosphorIcon}"
                   Text="{x:Static ph:PhosphorIcons.Default}"
                   FontSize="14"
                   TextColor="{DynamicResource AccentColor}" />
                                <Label Text="Other" FontSize="12" VerticalOptions="Center"
                   TextColor="{DynamicResource TextPrimary}" />
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Grocery -->
                        <Border Style="{StaticResource HoverButton}"
            BackgroundColor="{DynamicResource PageBackground}"
            Stroke="{DynamicResource CardBorder}"
            StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
            Padding="14,8" Margin="0,0,8,8">
                            <Border.Behaviors>
                                <behaviors:PressScaleBehavior />
                            </Border.Behaviors>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectCategoryFilterCommand}"
                                  CommandParameter="Grocery" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Label Style="{StaticResource PhosphorIcon}"
                   Text="{x:Static ph:PhosphorIcons.Grocery}"
                   FontSize="14"
                   TextColor="{DynamicResource AccentColor}" />
                                <Label Text="Grocery" FontSize="12" VerticalOptions="Center"
                   TextColor="{DynamicResource TextPrimary}" />

                    HorizontalOptions="Center" VerticalOptions="Center"
                    MaximumWidthRequest="340"
                    Margin="20,0" Padding="24,24">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="20">

                    <VerticalStackLayout Spacing="12">
                        <Label Text="Pick a week" FontSize="17" FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}" />
                        <Label Text="Showing the last 8 weeks"
                               FontSize="12" TextColor="{DynamicResource TextSecondary}" />
                    </VerticalStackLayout>

                    <CollectionView ItemsSource="{Binding WeekOptions}"
                                   SelectionMode="None"
                                   MaximumHeightRequest="380">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:WeekOption">
                                <Border BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding IsSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 12" StrokeThickness="0.8"
                                        Padding="14,11" Margin="0,0,0,6">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=SelectWeekCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="{Binding Label}" FontSize="13"
                                           FontAttributes="{Binding IsSelected, Converter={StaticResource BoolToFontAttr}}"
                                           TextColor="{Binding IsSelected, Converter={StaticResource BoolToChipText}}" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ── Year picker overlay ────────────────────────────────────────── -->
        <Grid IsVisible="{Binding IsYearPickerVisible}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding DismissYearPickerCommand}" />
            </Grid.GestureRecognizers>
            <controls:BlurOverlay />
            <Border BackgroundColor="{DynamicResource CardBackground}"
                    Style="{StaticResource ModalCard}"
                    StrokeShape="RoundRectangle 20"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    MaximumWidthRequest="300"
                    Margin="20,0" Padding="24,24">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="20">

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Pick a year" FontSize="17" FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}" />
                        <Label Text="Filter expenses for a specific year"
                               FontSize="12" TextColor="{DynamicResource TextSecondary}" />
                    </VerticalStackLayout>

                    <CollectionView ItemsSource="{Binding YearList}"
                                   SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="3"
                                             HorizontalItemSpacing="8"
                                             VerticalItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:Int32">
                                <Border BackgroundColor="{DynamicResource PageBackground}"
                                        Stroke="{DynamicResource CardBorder}"
                                        StrokeShape="RoundRectangle 12" StrokeThickness="0.8"
                                        Padding="0,12" HeightRequest="48">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=SelectYearCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="{Binding .}" FontSize="14"
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           TextColor="{DynamicResource TextPrimary}" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ── Detail modal ───────────────────────────────────────────────── -->
        <Grid IsVisible="{Binding IsDetailVisible}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding DismissDetailCommand}" />
            </Grid.GestureRecognizers>
            <controls:BlurOverlay />
            <Border BackgroundColor="{DynamicResource CardBackground}"
                    Style="{StaticResource ModalCard}"
                    StrokeShape="RoundRectangle 16"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    MaximumWidthRequest="360" Margin="20,0">
                <ScrollView MaximumHeightRequest="580">
                    <VerticalStackLayout Spacing="0">

                        <Image Source="{Binding SelectedItem.PhotoPath}"
                               IsVisible="{Binding SelectedItem.HasPhoto}"
                               Aspect="AspectFill" HeightRequest="180">
                            <Image.Clip>
                                <RoundRectangleGeometry Rect="0,0,2000,180"
                                                        CornerRadius="16,16,0,0" />
                            </Image.Clip>
                        </Image>

                        <VerticalStackLayout Padding="18,14,18,18" Spacing="0">

                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="0,0,0,8">
                                <Label Grid.Column="0"
                                       Text="{Binding SelectedItem.CategoryLabel}"
                                       FontSize="11" FontAttributes="Bold"
                                       CharacterSpacing="0.8" TextTransform="Uppercase"
                                       TextColor="{DynamicResource AccentColor}"
                                       VerticalOptions="Center" />
                                <Border Grid.Column="1"
                                        IsVisible="{Binding SelectedItem.IsGroceryGroup, Converter={StaticResource InverseBool}}"
                                        Style="{StaticResource HoverButton}"
                                        BackgroundColor="{DynamicResource AccentColorAlpha}"
                                        StrokeShape="RoundRectangle 980" Padding="12,6"
                                        VerticalOptions="Center">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding GoToEditExpenseCommand}"
                                                              CommandParameter="{Binding SelectedItem}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Edit" FontSize="12"
                                           TextColor="{DynamicResource AccentColor}" />
                                </Border>
                                <Border Grid.Column="2"
                                        Style="{StaticResource HoverButton}"
                                        BackgroundColor="#1Aff3b30"
                                        StrokeShape="RoundRectangle 980" Padding="12,6"
                                        VerticalOptions="Center">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding DeleteSelectedCommand}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Delete" FontSize="12" TextColor="#ff3b30" />
                                </Border>
                            </Grid>

                            <Label Text="{Binding SelectedItem.AmountFormatted}"
                                   FontSize="26" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}"
                                   Margin="0,0,0,10" />

                            <BoxView HeightRequest="0.5" Color="{DynamicResource CardBorder}"
                                     Margin="0,0,0,10" />

                            <VerticalStackLayout Spacing="10">

                                <VerticalStackLayout IsVisible="{Binding SelectedItem.HasTitle}" Spacing="3">
                                    <Label Text="Title" FontSize="10"
                                           TextColor="{DynamicResource TextSecondary}" />
                                    <Label Text="{Binding SelectedItem.Title}"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="{DynamicResource TextPrimary}" />
                                </VerticalStackLayout>

                                <Grid ColumnDefinitions="*,*">
                                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                                        <Label Text="Date" FontSize="10"
                                               TextColor="{DynamicResource TextSecondary}" />
                                        <Label Text="{Binding SelectedItem.DateFormatted}"
                                               FontSize="13" TextColor="{DynamicResource TextPrimary}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                                        <Label Text="Category" FontSize="10"
                                               TextColor="{DynamicResource TextSecondary}" />
                                        <Label Text="{Binding SelectedItem.CategoryLabel}"
                                               FontSize="13" TextColor="{DynamicResource TextPrimary}" />
                                    </VerticalStackLayout>
                                </Grid>

                                <VerticalStackLayout IsVisible="{Binding SelectedItem.HasNote}" Spacing="3">
                                    <Label Text="Note" FontSize="10"
                                           TextColor="{DynamicResource TextSecondary}" />
                                    <Label Text="{Binding SelectedItem.Note}"
                                           FontSize="13" TextColor="{DynamicResource TextPrimary}" />
                                </VerticalStackLayout>

                            </VerticalStackLayout>

                            <VerticalStackLayout IsVisible="{Binding SelectedItem.IsGroceryGroup}"
                                                 Margin="0,10,0,0">
                                <BoxView HeightRequest="0.5" Color="{DynamicResource CardBorder}"
                                         Margin="0,0,0,10" />
                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                    <Label Grid.Column="0" Text="Items"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="{DynamicResource TextPrimary}" />
                                    <Label Grid.Column="1" Text="Delete all"
                                           FontSize="12" TextColor="#ff3b30">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding DeleteAllGroceryItemsCommand}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                                <CollectionView ItemsSource="{Binding SelectedItem.GroceryItems}"
                                               SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:GroceryLineItem">
                                            <Grid ColumnDefinitions="*,Auto,Auto" Padding="0,8,0,8">
                                                <BoxView Grid.ColumnSpan="3" HeightRequest="0.5"
                                                         VerticalOptions="End"
                                                         Color="{DynamicResource CardBorder}" />
                                                <Label Grid.Column="0" Text="{Binding Name}"
                                                       FontSize="13" VerticalOptions="Center"
                                                       TextColor="{DynamicResource TextPrimary}" />
                                                <Label Grid.Column="1" Text="{Binding PriceFormatted}"
                                                       FontSize="13" FontAttributes="Bold"
                                                       TextColor="{DynamicResource AccentColor}"
                                                       Margin="0,0,12,0" VerticalOptions="Center" />
                                                <Label Grid.Column="2" Text="✕" FontSize="13"
                                                       TextColor="{DynamicResource TextSecondary}">
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=DeleteGroceryItemCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </Label.GestureRecognizers>
                                                </Label>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
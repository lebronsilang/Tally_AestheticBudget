<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Tally_AestheticBudget.Views.FeedPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Tally_AestheticBudget.ViewModels"
    xmlns:models="clr-namespace:Tally_AestheticBudget.Models"
    x:DataType="vm:FeedViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F7F6F2">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ── Header ──────────────────────────────────────────────────── -->
        <VerticalStackLayout Grid.Row="0" Padding="20,56,20,0" Spacing="2">
            <Label
                Text="Expenses"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="#1A1A18" />
            <Label
                Text="{Binding SummaryLabel}"
                FontSize="13"
                TextColor="#9E9D98" />
        </VerticalStackLayout>

        <!-- ── Filter chips ────────────────────────────────────────────── -->
        <ScrollView
            Grid.Row="1"
            Orientation="Horizontal"
            HorizontalScrollBarVisibility="Never"
            Margin="0,14,0,6">
            <HorizontalStackLayout Padding="20,0" Spacing="8">

                <!-- All -->
                <Border
                    BackgroundColor="{Binding IsFilterAll, Converter={StaticResource BoolToChipBg}}"
                    Stroke="{Binding IsFilterAll, Converter={StaticResource BoolToChipBorder}}"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0.5"
                    Padding="14,7">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FilterAllCommand}" />
                    </Border.GestureRecognizers>
                    <Label
                        Text="All"
                        FontSize="13"
                        FontAttributes="{Binding IsFilterAll, Converter={StaticResource BoolToFontAttr}}"
                        TextColor="{Binding IsFilterAll, Converter={StaticResource BoolToChipText}}" />
                </Border>

                <!-- This Year -->
                <Border
                    BackgroundColor="{Binding IsFilterYear, Converter={StaticResource BoolToChipBg}}"
                    Stroke="{Binding IsFilterYear, Converter={StaticResource BoolToChipBorder}}"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0.5"
                    Padding="14,7">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FilterYearCommand}" />
                    </Border.GestureRecognizers>
                    <Label
                        Text="This Year"
                        FontSize="13"
                        FontAttributes="{Binding IsFilterYear, Converter={StaticResource BoolToFontAttr}}"
                        TextColor="{Binding IsFilterYear, Converter={StaticResource BoolToChipText}}" />
                </Border>

                <!-- Month picker chip -->
                <Border
                    BackgroundColor="{Binding IsFilterMonth, Converter={StaticResource BoolToChipBg}}"
                    Stroke="{Binding IsFilterMonth, Converter={StaticResource BoolToChipBorder}}"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0.5"
                    Padding="14,7">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowMonthPickerCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="5">
                        <Label
                            Text="{Binding SelectedMonthLabel}"
                            FontSize="13"
                            FontAttributes="{Binding IsFilterMonth, Converter={StaticResource BoolToFontAttr}}"
                            TextColor="{Binding IsFilterMonth, Converter={StaticResource BoolToChipText}}" />
                        <Label Text="▾" FontSize="11"
                               TextColor="{Binding IsFilterMonth, Converter={StaticResource BoolToChipText}}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

            </HorizontalStackLayout>
        </ScrollView>

        <!-- ── Feed content ────────────────────────────────────────────── -->
        <RefreshView
            Grid.Row="2"
            Command="{Binding RefreshCommand}"
            IsRefreshing="{Binding IsRefreshing}">
            <Grid>

                <!-- Empty state -->
                <VerticalStackLayout
                    IsVisible="{Binding HasNoEntries}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Spacing="8"
                    Padding="40">
                    <Label Text="No expenses yet" FontSize="17" FontAttributes="Bold"
                           HorizontalOptions="Center" TextColor="#5F5E5A" />
                    <Label Text="Tap + to log your first expense"
                           FontSize="14" HorizontalOptions="Center" TextColor="#9E9D98" />
                </VerticalStackLayout>

                <!-- 2-column card grid -->
                <CollectionView
                    IsVisible="{Binding HasNoEntries, Converter={StaticResource InverseBool}}"
                    ItemsSource="{Binding FeedItems}"
                    SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout
                            Orientation="Vertical"
                            Span="2"
                            HorizontalItemSpacing="10"
                            VerticalItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.Header>
                        <BoxView HeightRequest="4" Color="Transparent" />
                    </CollectionView.Header>
                    <CollectionView.Footer>
                        <BoxView HeightRequest="100" Color="Transparent" />
                    </CollectionView.Footer>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:FeedCardItem">
                            <ContentView Padding="0">
                                <ContentView.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=OpenDetailCommand}"
                                        CommandParameter="{Binding .}" />
                                </ContentView.GestureRecognizers>
                                <Border
                                    BackgroundColor="White"
                                    StrokeThickness="0.5"
                                    Stroke="#E8E7E1"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="0">
                                    <Grid RowDefinitions="Auto,Auto,Auto">

                                        <!-- Photo -->
                                        <Image
                                            Grid.Row="0"
                                            Source="{Binding PhotoPath}"
                                            IsVisible="{Binding HasPhoto}"
                                            Aspect="AspectFill"
                                            HeightRequest="110">
                                            <Image.Clip>
                                                <RoundRectangleGeometry Rect="0,0,1000,110" CornerRadius="16,16,0,0" />
                                            </Image.Clip>
                                        </Image>

                                        <!-- Body -->
                                        <VerticalStackLayout Grid.Row="1" Padding="12,12,12,6" Spacing="4">

                                            <!-- Category row -->
                                            <HorizontalStackLayout Spacing="6">
                                                <BoxView
                                                    Color="{Binding Category, Converter={StaticResource CategoryToColor}}"
                                                    WidthRequest="8" HeightRequest="8"
                                                    CornerRadius="4"
                                                    VerticalOptions="Center" />
                                                <Label
                                                    Text="{Binding CategoryLabel}"
                                                    FontSize="11"
                                                    TextColor="#9E9D98"
                                                    VerticalOptions="Center" />
                                                <!-- Grocery item count badge -->
                                                <Border
                                                    IsVisible="{Binding IsGroceryGroup}"
                                                    BackgroundColor="#F0F0EC"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="5,2">
                                                    <Label Text="{Binding GroceryItemCountLabel}"
                                                           FontSize="10" TextColor="#5F5E5A" />
                                                </Border>
                                            </HorizontalStackLayout>

                                            <!-- Amount -->
                                            <Label
                                                Text="{Binding AmountFormatted}"
                                                FontSize="20"
                                                FontAttributes="Bold"
                                                TextColor="#1A1A18" />

                                            <!-- Note -->
                                            <Label
                                                Text="{Binding Note}"
                                                IsVisible="{Binding HasNote}"
                                                FontSize="13"
                                                LineBreakMode="TailTruncation"
                                                MaxLines="2"
                                                TextColor="#5F5E5A" />
                                        </VerticalStackLayout>

                                        <!-- Date -->
                                        <Label
                                            Grid.Row="2"
                                            Text="{Binding Date, Converter={StaticResource DateToDisplay}}"
                                            FontSize="11"
                                            Margin="12,0,12,10"
                                            TextColor="#9E9D98" />

                                    </Grid>
                                </Border>
                            </ContentView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </Grid>
        </RefreshView>

        <!-- ── Month picker overlay ─────────────────────────────────────── -->
        <Grid Grid.RowSpan="3" IsVisible="{Binding IsMonthPickerVisible}" BackgroundColor="#80000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding DismissMonthPickerCommand}" />
            </Grid.GestureRecognizers>
            <Border
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 20"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="16,0,16,48"
                Padding="20,24">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Select month" FontSize="16" FontAttributes="Bold" TextColor="#1A1A18" />
                    <!-- Year selector -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="24">
                        <Label Text="‹" FontSize="22" TextColor="#1A1A18">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PreviousYearCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Text="{Binding PickerYear}" FontSize="16" VerticalOptions="Center" TextColor="#1A1A18" />
                        <Label Text="›" FontSize="22" TextColor="#1A1A18">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding NextYearCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                    <!-- Month grid -->
                    <CollectionView ItemsSource="{Binding MonthOptions}" SelectionMode="None" HeightRequest="176">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="4"
                                             HorizontalItemSpacing="8" VerticalItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:MonthOption">
                                <Border
                                    BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToChipBg}}"
                                    Stroke="{Binding IsSelected, Converter={StaticResource BoolToChipBorder}}"
                                    StrokeShape="RoundRectangle 10"
                                    StrokeThickness="0.5"
                                    Padding="0,8">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=SelectMonthCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Label
                                        Text="{Binding ShortName}"
                                        FontSize="13"
                                        HorizontalOptions="Center"
                                        TextColor="{Binding IsSelected, Converter={StaticResource BoolToChipText}}" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ── Detail bottom sheet ──────────────────────────────────────── -->
        <Grid Grid.RowSpan="3" IsVisible="{Binding IsDetailVisible}" BackgroundColor="#80000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding DismissDetailCommand}" />
            </Grid.GestureRecognizers>
            <Border
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24,24,0,0"
                VerticalOptions="End">
                <Grid RowDefinitions="Auto,Auto,*">

                    <!-- Drag handle -->
                    <BoxView Grid.Row="0"
                             WidthRequest="36" HeightRequest="4" CornerRadius="2"
                             Color="#DDDDD8" HorizontalOptions="Center" Margin="0,12,0,0" />

                    <!-- Detail header -->
                    <Grid Grid.Row="1" Padding="20,14,20,0" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="3">
                            <HorizontalStackLayout Spacing="8">
                                <BoxView
                                    Color="{Binding SelectedItem.Category, Converter={StaticResource CategoryToColor}}"
                                    WidthRequest="10" HeightRequest="10" CornerRadius="5"
                                    VerticalOptions="Center" />
                                <Label Text="{Binding SelectedItem.CategoryLabel}"
                                       FontSize="13" TextColor="#9E9D98" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding SelectedItem.AmountFormatted}"
                                   FontSize="30" FontAttributes="Bold" TextColor="#1A1A18" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                BackgroundColor="#FEF0EF" StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                Padding="12,8" VerticalOptions="Start">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding DeleteSelectedCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="Delete" FontSize="13" TextColor="#D9534F" />
                        </Border>
                    </Grid>

                    <!-- Detail scroll content -->
                    <ScrollView Grid.Row="2" Padding="20,14,20,48">
                        <VerticalStackLayout Spacing="0">

                            <!-- Photo -->
                            <Image Source="{Binding SelectedItem.PhotoPath}"
                                   IsVisible="{Binding SelectedItem.HasPhoto}"
                                   Aspect="AspectFill" HeightRequest="200" Margin="0,0,0,16">
                                <Image.Clip>
                                    <RoundRectangleGeometry Rect="0,0,1000,200" CornerRadius="12" />
                                </Image.Clip>
                            </Image>

                            <BoxView HeightRequest="0.5" Color="#EBEBEB" Margin="0,0,0,14" />

                            <!-- Date + category row -->
                            <Grid ColumnDefinitions="*,*" Margin="0,0,0,14">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="Date" FontSize="12" TextColor="#9E9D98" />
                                    <Label Text="{Binding SelectedItem.DateFormatted}" FontSize="15" TextColor="#1A1A18" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="Category" FontSize="12" TextColor="#9E9D98" />
                                    <Label Text="{Binding SelectedItem.CategoryLabel}" FontSize="15" TextColor="#1A1A18" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Note -->
                            <VerticalStackLayout IsVisible="{Binding SelectedItem.HasNote}" Margin="0,0,0,14">
                                <Label Text="Note" FontSize="12" TextColor="#9E9D98" />
                                <Label Text="{Binding SelectedItem.Note}" FontSize="15" TextColor="#1A1A18" />
                            </VerticalStackLayout>

                            <!-- Grocery items list -->
                            <VerticalStackLayout IsVisible="{Binding SelectedItem.IsGroceryGroup}">
                                <BoxView HeightRequest="0.5" Color="#EBEBEB" Margin="0,0,0,12" />
                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                                    <Label Grid.Column="0" Text="Items" FontSize="14"
                                           FontAttributes="Bold" TextColor="#1A1A18" />
                                    <Label Grid.Column="1" Text="Delete all" FontSize="13" TextColor="#D9534F">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding DeleteAllGroceryItemsCommand}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                                <CollectionView ItemsSource="{Binding SelectedItem.GroceryItems}" SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:GroceryLineItem">
                                            <Grid ColumnDefinitions="*,Auto,Auto" Padding="0,10,0,10">
                                                <Label Grid.Column="0" Text="{Binding Name}"
                                                       FontSize="14" VerticalOptions="Center" TextColor="#1A1A18" />
                                                <Label Grid.Column="1" Text="{Binding PriceFormatted}"
                                                       FontSize="14" Margin="0,0,14,0"
                                                       VerticalOptions="Center" TextColor="#5F5E5A" />
                                                <Label Grid.Column="2" Text="✕" FontSize="13" TextColor="#9E9D98">
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=DeleteGroceryItemCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </Label.GestureRecognizers>
                                                </Label>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</ContentPage>

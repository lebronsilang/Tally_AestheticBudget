<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Tally_AestheticBudget.Views.WishlistPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Tally_AestheticBudget.ViewModels"
    xmlns:models="clr-namespace:Tally_AestheticBudget.Models"
    xmlns:controls="clr-namespace:Tally_AestheticBudget.Controls"
    xmlns:ph="clr-namespace:Tally_AestheticBudget.Helpers"
    x:DataType="vm:WishlistViewModel"
    Shell.NavBarIsVisible="True"
    BackgroundColor="{DynamicResource PageBackground}">

    <!-- ── Outer drawer: item detail panel ─────────────────────────────────── -->
    <controls:DrawerHost
        IsOpen="{Binding IsDetailVisible}"
        OpenFromLeft="False"
        DrawerWidth="420"
        CloseCommand="{Binding DismissDetailCommand}">

        <controls:DrawerHost.BodyContent>
            <Grid RowDefinitions="Auto,*">

        <controls:DrawerHost
            Grid.RowSpan="2"
            IsOpen="{Binding IsAddModalVisible}"
            OpenFromLeft="{Binding ExpensePanelOnLeft}"
            DrawerWidth="380"
            CloseCommand="{Binding DismissAddModalCommand}">

            <controls:DrawerHost.BodyContent>
                <Grid RowDefinitions="Auto,*">

                    <!-- ── Floating header card ───────────────────────────────────────── -->
                    <Border Grid.Row="0"
                BackgroundColor="{DynamicResource CardBackground}"
                Stroke="{DynamicResource CardBorder}"
                StrokeThickness="1" StrokeShape="RoundRectangle 20"
                Padding="20,18,20,16"
                Margin="16,16,16,0">
                        <VerticalStackLayout Spacing="14">

                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="Dream Board" FontFamily="DisplayFont"
                               FontSize="28" TextColor="{DynamicResource TextPrimary}" />
                                    <Label Text="{Binding StatsLabel}" FontSize="13"
                               TextColor="{DynamicResource TextSecondary}" />
                                </VerticalStackLayout>
                                <Border Grid.Column="1"
                            Style="{StaticResource HoverButton}"
                            BackgroundColor="{DynamicResource AccentColor}"
                            StrokeShape="RoundRectangle 980"
                            Padding="14,8" VerticalOptions="Center">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OpenAddModalCommand}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="+ Add Wish" FontSize="13" FontAttributes="Bold"
                               TextColor="{DynamicResource OnAccentColor}" />
                                </Border>
                            </Grid>

                            <!-- Filter chips -->
                            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                                <HorizontalStackLayout Spacing="8">
                                    <Border Style="{StaticResource HoverButton}"
                                BackgroundColor="{Binding IsFilterAll, Converter={StaticResource BoolToChipBg}}"
                                Stroke="{Binding IsFilterAll, Converter={StaticResource BoolToChipBorder}}"
                                StrokeShape="RoundRectangle 980" StrokeThickness="0.8" Padding="16,7">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding FilterAllCommand}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="All" FontSize="13"
                                   FontAttributes="{Binding IsFilterAll, Converter={StaticResource BoolToFontAttr}}"
                                   TextColor="{Binding IsFilterAll, Converter={StaticResource BoolToChipText}}" />
                                    </Border>
                                    <Border Style="{StaticResource HoverButton}"
                                BackgroundColor="{Binding IsFilterPlanned, Converter={StaticResource BoolToChipBg}}"
                                Stroke="{Binding IsFilterPlanned, Converter={StaticResource BoolToChipBorder}}"
                                StrokeShape="RoundRectangle 980" StrokeThickness="0.8" Padding="16,7">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding FilterPlannedCommand}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="Planned" FontSize="13"
                                   FontAttributes="{Binding IsFilterPlanned, Converter={StaticResource BoolToFontAttr}}"
                                   TextColor="{Binding IsFilterPlanned, Converter={StaticResource BoolToChipText}}" />
                                    </Border>
                                    <Border Style="{StaticResource HoverButton}"
                                BackgroundColor="{Binding IsFilterBought, Converter={StaticResource BoolToChipBg}}"
                                Stroke="{Binding IsFilterBought, Converter={StaticResource BoolToChipBorder}}"
                                StrokeShape="RoundRectangle 980" StrokeThickness="0.8" Padding="16,7">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding FilterBoughtCommand}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="Bought" FontSize="13"
                                   FontAttributes="{Binding IsFilterBought, Converter={StaticResource BoolToFontAttr}}"
                                   TextColor="{Binding IsFilterBought, Converter={StaticResource BoolToChipText}}" />
                                    </Border>
                                    <Border Style="{StaticResource HoverButton}"
                                BackgroundColor="{Binding IsFilterWant, Converter={StaticResource BoolToChipBg}}"
                                Stroke="{Binding IsFilterWant, Converter={StaticResource BoolToChipBorder}}"
                                StrokeShape="RoundRectangle 980" StrokeThickness="0.8" Padding="16,7">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding FilterWantCommand}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="Want" FontSize="13"
                                   FontAttributes="{Binding IsFilterWant, Converter={StaticResource BoolToFontAttr}}"
                                   TextColor="{Binding IsFilterWant, Converter={StaticResource BoolToChipText}}" />
                                    </Border>
                                    <Border Style="{StaticResource HoverButton}"
                                BackgroundColor="{Binding IsFilterNeed, Converter={StaticResource BoolToChipBg}}"
                                Stroke="{Binding IsFilterNeed, Converter={StaticResource BoolToChipBorder}}"
                                StrokeShape="RoundRectangle 980" StrokeThickness="0.8" Padding="16,7">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding FilterNeedCommand}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="Need" FontSize="13"
                                   FontAttributes="{Binding IsFilterNeed, Converter={StaticResource BoolToFontAttr}}"
                                   TextColor="{Binding IsFilterNeed, Converter={StaticResource BoolToChipText}}" />
                                    </Border>
                                    <Border Style="{StaticResource HoverButton}"
                                BackgroundColor="{Binding IsFilterSomeday, Converter={StaticResource BoolToChipBg}}"
                                Stroke="{Binding IsFilterSomeday, Converter={StaticResource BoolToChipBorder}}"
                                StrokeShape="RoundRectangle 980" StrokeThickness="0.8" Padding="16,7">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding FilterSomedayCommand}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="Someday" FontSize="13"
                                   FontAttributes="{Binding IsFilterSomeday, Converter={StaticResource BoolToFontAttr}}"
                                   TextColor="{Binding IsFilterSomeday, Converter={StaticResource BoolToChipText}}" />
                                    </Border>
                                </HorizontalStackLayout>
                            </ScrollView>

                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Wish masonry grid ──────────────────────────────────────────── -->
                    <Grid Grid.Row="1">

                        <VerticalStackLayout
                IsVisible="{Binding HasNoItems}"
                HorizontalOptions="Center" VerticalOptions="Center"
                Spacing="10" Padding="40">
                            <Label Style="{StaticResource PhosphorIcon}"
                   Text="{x:Static ph:PhosphorIcons.Default}"
                   FontSize="20"
                   TextColor="{DynamicResource AccentColor}" />
                            <Label Text="Your dream board is empty."
                       FontSize="15" HorizontalOptions="Center"
                       TextColor="{DynamicResource TextSecondary}" />
                            <Label Text="Add something you want!"
                       FontSize="13" HorizontalOptions="Center"
                       TextColor="{DynamicResource TextSecondary}" />
                        </VerticalStackLayout>

                        <ScrollView
                x:Name="MasonryScrollView"
                IsVisible="{Binding ShowMasonryArea}">
                            <Grid
                    x:Name="MasonryGrid"
                    ColumnSpacing="10"
                    Padding="14,12,14,100"
                    VerticalOptions="Start" />
                        </ScrollView>

                        <!-- List view (alternate to masonry) -->
                        <ScrollView IsVisible="{Binding ShowListArea}">
                            <VerticalStackLayout Spacing="8" Padding="14,12,14,100"
                                     BindableLayout.ItemsSource="{Binding DisplayedItems}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:WishCardItem">
                                        <Border BackgroundColor="{DynamicResource CardBackground}"
                                    Stroke="{DynamicResource CardBorder}"
                                    StrokeThickness="1" StrokeShape="RoundRectangle 16"
                                    Padding="12">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WishlistViewModel}}, Path=OpenDetailCommand}"
                                        CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                <Image Grid.Column="0" Source="{Binding PhotoPath}"
                                           Aspect="AspectFill" WidthRequest="52" HeightRequest="52"
                                           VerticalOptions="Center"
                                           IsVisible="{Binding ListShowThumbnail}">
                                                    <Image.Clip>
                                                        <RoundRectangleGeometry Rect="0,0,52,52" CornerRadius="12" />
                                                    </Image.Clip>
                                                </Image>
                                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                    <HorizontalStackLayout Spacing="5">
                                                        <Label Text="{Binding PriorityLabel}" FontSize="10"
                                                   FontAttributes="Bold" CharacterSpacing="0.5"
                                                   TextColor="{DynamicResource AccentColor}" />
                                                        <Label Text="·" FontSize="10" VerticalOptions="Center"
                                                   TextColor="{DynamicResource TextSecondary}" />
                                                        <Label Text="{Binding CategoryLabel}" FontSize="10"
                                                   VerticalOptions="Center"
                                                   TextColor="{DynamicResource TextSecondary}" />
                                                        <Label Text="📷" FontSize="10" VerticalOptions="Center"
                                                   IsVisible="{Binding ListShowPhotoIndicator}" />
                                                        <Label Text="📌" FontSize="10" VerticalOptions="Center"
                                                   IsVisible="{Binding IsPinned}" />
                                                    </HorizontalStackLayout>
                                                    <Label Text="{Binding Name}" FontSize="15" FontAttributes="Bold"
                                               LineBreakMode="TailTruncation"
                                               TextColor="{DynamicResource TextPrimary}" />
                                                    <Label Text="{Binding Caption}" FontSize="12" MaxLines="1"
                                               LineBreakMode="TailTruncation" IsVisible="{Binding HasCaption}"
                                               TextColor="{DynamicResource TextSecondary}" />
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="2" Spacing="2"
                                                         VerticalOptions="Center" HorizontalOptions="End">
                                                    <Label Text="{Binding PriceFormatted}" FontSize="15"
                                               FontAttributes="Bold" HorizontalOptions="End"
                                               TextColor="{DynamicResource TextPrimary}" />
                                                    <Label Text="{Binding StatusLabel}" FontSize="10"
                                               HorizontalOptions="End"
                                               TextColor="{DynamicResource TextSecondary}" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </ScrollView>

                    </Grid>

                    <!-- ── Add Wish modal ─────────────────────────────────────────────── -->
                </Grid>
            </controls:DrawerHost.BodyContent>

            <controls:DrawerHost.DrawerContent>
                <Border BackgroundColor="{DynamicResource CardBackground}"
                    
                    StrokeThickness="0"
                    IsVisible="{Binding IsAddModalVisible}"
                    HorizontalOptions="Fill" VerticalOptions="Fill"
                    >
                    <ScrollView VerticalOptions="Fill">
                        <VerticalStackLayout Padding="18,16,18,18" Spacing="12">

                            <Grid ColumnDefinitions="*,Auto">
                                <HorizontalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">

                                    <Label Text="New Wish"
                                   FontFamily="DisplayFont"
                                   FontSize="18"
                                   TextColor="{DynamicResource TextPrimary}"
                                   VerticalOptions="Center" />

                                    <Label Style="{StaticResource PhosphorIcon}"
                                   Text="{x:Static ph:PhosphorIcons.Sparkle}"
                                   FontSize="20"
                                   TextColor="{DynamicResource AccentColor}" />

                                </HorizontalStackLayout>
                                <Border Grid.Column="1"
                                    BackgroundColor="{DynamicResource PageBackground}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 980"
                                    WidthRequest="28" HeightRequest="28">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding DismissAddModalCommand}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="✕" FontSize="12"
                                       TextColor="{DynamicResource TextSecondary}"
                                       IsVisible="{Binding IsAddModalVisible}"
                    HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="Item Name" FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                                <Border BackgroundColor="{DynamicResource PageBackground}"
                                    Stroke="{DynamicResource CardBorder}"
                                    StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                    Padding="12,0">
                                    <Entry Text="{Binding NewName}"
                                       Placeholder="What do you want?"
                                       PlaceholderColor="#C0C0C5" FontSize="13"
                                       TextColor="{DynamicResource TextPrimary}"
                                       BackgroundColor="Transparent" HeightRequest="40" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding PriceLabelText}" FontSize="11" FontAttributes="Bold"
                                    TextColor="{DynamicResource TextPrimary}" />
                                <Border BackgroundColor="{DynamicResource PageBackground}"
                                    Stroke="{DynamicResource CardBorder}"
                                    StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                    Padding="12,0">
                                    <Entry Text="{Binding NewPrice}" Placeholder="0.00"
                                       PlaceholderColor="#C0C0C5" Keyboard="Numeric"
                                       FontSize="13" TextColor="{DynamicResource TextPrimary}"
                                       BackgroundColor="Transparent" HeightRequest="40" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="Priority" FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                                <HorizontalStackLayout Spacing="6">
                                    <Border BackgroundColor="{Binding IsWantSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding IsWantSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectPriorityCommand}" CommandParameter="Want" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                            <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Heart}"
                                           FontSize="20"
                                           TextColor="{Binding IsWantSelected, Converter={StaticResource BoolToIconColor}}"  />

                                            <Label Text="Want"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding IsWantSelected, Converter={StaticResource BoolToChipText}}" />

                                        </HorizontalStackLayout>
                                    </Border>
                                    <Border BackgroundColor="{Binding IsNeedSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding IsNeedSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectPriorityCommand}" CommandParameter="Need" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                            <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.WarningCircle}"
                                           FontSize="20"
                                           TextColor="{Binding IsNeedSelected, Converter={StaticResource BoolToIconColor}}" />

                                            <Label Text="Need"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding IsNeedSelected, Converter={StaticResource BoolToChipText}}" />

                                        </HorizontalStackLayout>
                                    </Border>
                                    <Border BackgroundColor="{Binding IsSomedaySelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding IsSomedaySelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectPriorityCommand}" CommandParameter="Someday" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                            <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Hourglass}"
                                           FontSize="20"
                                           TextColor="{Binding IsSomedaySelected, Converter={StaticResource BoolToIconColor}}" />

                                            <Label Text="Someday"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding IsSomedaySelected, Converter={StaticResource BoolToChipText}}" />

                                        </HorizontalStackLayout>
                                    </Border>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="Category" FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                                <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start"
                                        AlignItems="Center">
                                    <Border BackgroundColor="{Binding IsNewFoodSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding IsNewFoodSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectWishCategoryCommand}" CommandParameter="Food" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                            <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Food}"
                                           FontSize="20"
                                           TextColor="{Binding IsNewFoodSelected, Converter={StaticResource BoolToIconColor}}" />

                                            <Label Text="Food"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding IsNewFoodSelected, Converter={StaticResource BoolToChipText}}" />

                                        </HorizontalStackLayout>
                                    </Border>
                                    <Border BackgroundColor="{Binding IsNewShoppingSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding IsNewShoppingSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectWishCategoryCommand}" CommandParameter="Shopping" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                            <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Shopping}"
                                           FontSize="20"
                                           TextColor="{Binding IsNewShoppingSelected, Converter={StaticResource BoolToIconColor}}" />

                                            <Label Text="Shopping"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding IsNewShoppingSelected, Converter={StaticResource BoolToChipText}}" />

                                        </HorizontalStackLayout>
                                    </Border>
                                    <Border BackgroundColor="{Binding IsNewHealthSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding IsNewHealthSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectWishCategoryCommand}" CommandParameter="Health" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                            <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Health}"
                                           FontSize="20"
                                           TextColor="{Binding IsNewHealthSelected, Converter={StaticResource BoolToIconColor}}" />

                                            <Label Text="Health"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding IsNewHealthSelected, Converter={StaticResource BoolToChipText}}" />

                                        </HorizontalStackLayout>
                                    </Border>
                                    <Border BackgroundColor="{Binding IsNewFunSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding IsNewFunSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectWishCategoryCommand}" CommandParameter="Fun" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                            <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Fun}"
                                           FontSize="20"
                                           TextColor="{Binding IsNewFunSelected, Converter={StaticResource BoolToIconColor}}" />

                                            <Label Text="Fun"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding IsNewFunSelected, Converter={StaticResource BoolToChipText}}" />

                                        </HorizontalStackLayout>
                                    </Border>
                                    <Border BackgroundColor="{Binding IsNewOtherSelected, Converter={StaticResource BoolToChipBg}}"
                                        Stroke="{Binding IsNewOtherSelected, Converter={StaticResource BoolToChipBorder}}"
                                        StrokeShape="RoundRectangle 980" StrokeThickness="0.8"
                                        Padding="12,6" Margin="0,0,6,6">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectWishCategoryCommand}" CommandParameter="Other" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                            <Label Style="{StaticResource PhosphorIcon}"
                                           Text="{x:Static ph:PhosphorIcons.Default}"
                                           FontSize="20"
                                           TextColor="{Binding IsNewOtherSelected, Converter={StaticResource BoolToIconColor}}" />

                                            <Label Text="other"
                                           FontSize="12"
                                           VerticalOptions="Center"
                                           TextColor="{Binding IsNewOtherSelected, Converter={StaticResource BoolToChipText}}" />

                                        </HorizontalStackLayout>
                                    </Border>
                                </FlexLayout>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="Caption (optional)" FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                                <Border BackgroundColor="{DynamicResource PageBackground}"
                                    Stroke="{DynamicResource CardBorder}"
                                    StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                    Padding="12,0">
                                    <Entry Text="{Binding NewCaption}"
                                       Placeholder="for my soft girl era..."
                                       PlaceholderColor="#C0C0C5" FontSize="13"
                                       TextColor="{DynamicResource TextPrimary}"
                                       BackgroundColor="Transparent" HeightRequest="40" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="Target Month (optional)" FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                                <Border BackgroundColor="{DynamicResource PageBackground}"
                                    Stroke="{DynamicResource CardBorder}"
                                    StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                    Padding="12,0">
                                    <Entry Text="{Binding NewTargetMonth}"
                                       Placeholder="e.g. 2026-06"
                                       PlaceholderColor="#C0C0C5" FontSize="13"
                                       TextColor="{DynamicResource TextPrimary}"
                                       BackgroundColor="Transparent" HeightRequest="40" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="Photo (optional)" FontSize="11" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />

                                <!-- Picker area — collapses once a photo is chosen -->
                                <VerticalStackLayout IsVisible="{Binding NewHasPhoto, Converter={StaticResource InverseBool}}"
                                                 Spacing="8">

                                    <!-- ── 2×2 source grid ── -->
                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                                      ColumnSpacing="8" RowSpacing="8">

                                        <!-- From Files -->
                                        <Border Grid.Row="0" Grid.Column="0"
                                            BackgroundColor="{DynamicResource PageBackground}"
                                            Stroke="{DynamicResource CardBorder}"
                                            StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                            Padding="0,14" Style="{StaticResource HoverButton}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding PickWishPhotoCommand}" />
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                                <Label Style="{StaticResource PhosphorIcon}"
                                                   Text="{x:Static ph:PhosphorIcons.FolderOpen}"
                                                   FontSize="18" HorizontalOptions="Center"
                                                   TextColor="{DynamicResource AccentColor}" />
                                                <Label Text="From Files" FontSize="11"
                                                   HorizontalOptions="Center"
                                                   TextColor="{DynamicResource TextSecondary}" />
                                            </VerticalStackLayout>
                                        </Border>

                                        <!-- Unsplash -->
                                        <Border Grid.Row="0" Grid.Column="1"
                                            BackgroundColor="{DynamicResource PageBackground}"
                                            Stroke="{DynamicResource CardBorder}"
                                            StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                            Padding="0,14" Style="{StaticResource HoverButton}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding ToggleUnsplashPanelCommand}" />
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                                <Label Style="{StaticResource PhosphorIcon}"
                                                   Text="{x:Static ph:PhosphorIcons.Globe}"
                                                   FontSize="18" HorizontalOptions="Center"
                                                   TextColor="{DynamicResource AccentColor}" />
                                                <Label Text="Unsplash" FontSize="11"
                                                   HorizontalOptions="Center"
                                                   TextColor="{DynamicResource TextSecondary}" />
                                            </VerticalStackLayout>
                                        </Border>

                                        <!-- Paste Image -->
                                        <Border Grid.Row="1" Grid.Column="0"
                                            BackgroundColor="{DynamicResource PageBackground}"
                                            Stroke="{DynamicResource CardBorder}"
                                            StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                            Padding="0,14" Style="{StaticResource HoverButton}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding PasteWishImageCommand}" />
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                                <Label Style="{StaticResource PhosphorIcon}"
                                                   Text="{x:Static ph:PhosphorIcons.ClipboardText}"
                                                   FontSize="18" HorizontalOptions="Center"
                                                   TextColor="{DynamicResource AccentColor}" />
                                                <Label Text="Paste Image" FontSize="11"
                                                   HorizontalOptions="Center"
                                                   TextColor="{DynamicResource TextSecondary}" />
                                            </VerticalStackLayout>
                                        </Border>

                                        <!-- Paste URL -->
                                        <Border Grid.Row="1" Grid.Column="1"
                                            BackgroundColor="{DynamicResource PageBackground}"
                                            Stroke="{DynamicResource CardBorder}"
                                            StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                            Padding="0,14" Style="{StaticResource HoverButton}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding TogglePasteUrlRowCommand}" />
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                                <Label Style="{StaticResource PhosphorIcon}"
                                                   Text="{x:Static ph:PhosphorIcons.Link}"
                                                   FontSize="18" HorizontalOptions="Center"
                                                   TextColor="{DynamicResource AccentColor}" />
                                                <Label Text="Paste URL" FontSize="11"
                                                   HorizontalOptions="Center"
                                                   TextColor="{DynamicResource TextSecondary}" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </Grid>

                                    <!-- ── Unsplash in-drawer panel (Wish) ── -->
                                    <VerticalStackLayout IsVisible="{Binding IsUnsplashPanelOpen}"
                                                     Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <Border Grid.Column="0"
                                                BackgroundColor="{DynamicResource PageBackground}"
                                                Stroke="{DynamicResource CardBorder}"
                                                StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                                Padding="12,0">
                                                <Entry Text="{Binding UnsplashQuery}"
                                                   Placeholder="Search Unsplash…"
                                                   PlaceholderColor="#C0C0C5" FontSize="13"
                                                   TextColor="{DynamicResource TextPrimary}"
                                                   BackgroundColor="Transparent" HeightRequest="40"
                                                   ReturnCommand="{Binding SearchUnsplashCommand}" />
                                            </Border>
                                            <Border Grid.Column="1"
                                                BackgroundColor="{DynamicResource AccentColor}"
                                                StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                                Padding="14,0" Style="{StaticResource HoverButton}">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding SearchUnsplashCommand}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="Search" FontSize="13" FontAttributes="Bold"
                                                   TextColor="{DynamicResource OnAccentColor}"
                                                   VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                        <ActivityIndicator IsRunning="{Binding IsUnsplashLoading}"
                                                       IsVisible="{Binding IsUnsplashLoading}"
                                                       Color="{DynamicResource AccentColor}"
                                                       HorizontalOptions="Center" />
                                        <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start"
                                                BindableLayout.ItemsSource="{Binding UnsplashResults}">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate>
                                                    <Border WidthRequest="106" HeightRequest="80"
                                                        Margin="0,0,4,4"
                                                        StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                                        Style="{StaticResource HoverButton}">
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                            Command="{Binding BindingContext.SelectUnsplashPhotoCommand,
                                                                      Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                            CommandParameter="{Binding BindingContext,
                                                                      Source={RelativeSource AncestorType={x:Type Border}}}" />
                                                        </Border.GestureRecognizers>
                                                        <Image Source="{Binding ThumbUrl}" Aspect="AspectFill">
                                                            <Image.Clip>
                                                                <RoundRectangleGeometry Rect="0,0,106,80"
                                                                                    CornerRadius="8" />
                                                            </Image.Clip>
                                                        </Image>
                                                    </Border>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </FlexLayout>
                                        <Border IsVisible="{Binding HasMoreUnsplashPages}"
                                            BackgroundColor="{DynamicResource PageBackground}"
                                            Stroke="{DynamicResource AccentColor}"
                                            StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                            Padding="0,10" Style="{StaticResource HoverButton}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding LoadMoreUnsplashCommand}" />
                                            </Border.GestureRecognizers>
                                            <Label Text="Load more" FontSize="12"
                                               TextColor="{DynamicResource AccentColor}"
                                               HorizontalOptions="Center" />
                                        </Border>
                                    </VerticalStackLayout>

                                    <!-- ── Paste URL row (Wish) ── -->
                                    <Grid IsVisible="{Binding IsPasteUrlRowOpen}"
                                      ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Border Grid.Column="0"
                                            BackgroundColor="{DynamicResource PageBackground}"
                                            Stroke="{DynamicResource CardBorder}"
                                            StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                            Padding="12,0">
                                            <Entry Text="{Binding PasteUrlText}"
                                               Placeholder="Paste image URL…"
                                               PlaceholderColor="#C0C0C5" FontSize="13"
                                               TextColor="{DynamicResource TextPrimary}"
                                               BackgroundColor="Transparent" HeightRequest="40" />
                                        </Border>
                                        <Border Grid.Column="1"
                                            BackgroundColor="{DynamicResource AccentColor}"
                                            StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                            Padding="14,0" Style="{StaticResource HoverButton}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding PasteWishUrlCommand}" />
                                            </Border.GestureRecognizers>
                                            <Label Text="Download" FontSize="13" FontAttributes="Bold"
                                               TextColor="{DynamicResource OnAccentColor}"
                                               VerticalOptions="Center" />
                                        </Border>
                                    </Grid>

                                </VerticalStackLayout>

                                <!-- ── Preview strip (unchanged) ── -->
                                <VerticalStackLayout IsVisible="{Binding NewHasPhoto}" Spacing="0">
                                    <Border BackgroundColor="{DynamicResource PageBackground}"
                                        Stroke="{DynamicResource CardBorder}"
                                        StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                        Padding="0">
                                        <Grid RowDefinitions="Auto,Auto">
                                            <Image Grid.Row="0" Source="{Binding NewPhotoPath}"
                                               Aspect="AspectFill" HeightRequest="110">
                                                <Image.Clip>
                                                    <RoundRectangleGeometry Rect="0,0,1000,110"
                                                                        CornerRadius="10,10,0,0" />
                                                </Image.Clip>
                                            </Image>
                                            <Border Grid.Row="1" BackgroundColor="#1Fff3b30"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 0,0,10,10"
                                                Padding="0,7">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding RemoveWishPhotoCommand}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="✕ Remove photo" FontSize="12"
                                                   TextColor="#ff3b30"
                                                   HorizontalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </VerticalStackLayout>
                            </VerticalStackLayout>

                            <Border BackgroundColor="{DynamicResource AccentColor}"
                                StrokeThickness="0"
                                Style="{StaticResource HoverButton}"
                                StrokeShape="RoundRectangle 980" Padding="0,12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SaveWishItemCommand}" />
                                </Border.GestureRecognizers>
                                <Label Text="Add to Dream Board" FontSize="13" FontAttributes="Bold"
                                   TextColor="{DynamicResource OnAccentColor}" HorizontalOptions="Center" />
                            </Border>

                        </VerticalStackLayout>
                    </ScrollView>
                </Border>

            </controls:DrawerHost.DrawerContent>

        </controls:DrawerHost>

            </Grid>
        </controls:DrawerHost.BodyContent>

        <!-- ── Detail panel content ──────────────────────────────────────── -->
        <controls:DrawerHost.DrawerContent>
            <Border BackgroundColor="{DynamicResource CardBackground}"
                    StrokeThickness="0"
                    HorizontalOptions="Fill" VerticalOptions="Fill">
                <Grid>
                <ScrollView>
                    <VerticalStackLayout Spacing="0">

                        <Grid IsVisible="{Binding SelectedItem.HasPhoto}">
                            <Image Source="{Binding SelectedItem.PhotoPath}"
                                   Aspect="AspectFill" HeightRequest="300">
                                <Image.Clip>
                                    <RoundRectangleGeometry Rect="0,0,1000,300"
                                                            CornerRadius="16,16,0,0" />
                                </Image.Clip>
                            </Image>

                            <BoxView HeightRequest="300" InputTransparent="True">
                                <BoxView.Clip>
                                    <RoundRectangleGeometry Rect="0,0,1000,300"
                                                            CornerRadius="16,16,0,0" />
                                </BoxView.Clip>
                                <BoxView.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="Transparent" Offset="0.0" />
                                        <GradientStop Color="#40000000" Offset="0.45" />
                                        <GradientStop Color="#CC000000" Offset="1.0" />
                                    </LinearGradientBrush>
                                </BoxView.Background>
                            </BoxView>

                            <VerticalStackLayout Spacing="3" VerticalOptions="End"
                                                  Padding="18,0,18,16">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="{Binding SelectedItem.PriorityLabel}"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="#FFFFFF" />
                                    <Label Text="·" FontSize="11"
                                           TextColor="#CCFFFFFF" />
                                    <Label Text="{Binding SelectedItem.CategoryLabel}"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="#CCFFFFFF"
                                           TextTransform="Uppercase" CharacterSpacing="0.4" />
                                </HorizontalStackLayout>

                                <Label Text="{Binding SelectedItem.Name}"
                                       FontSize="19" FontAttributes="Bold"
                                       TextColor="#FFFFFF" />
                                <Label Text="{Binding SelectedItem.PriceFormatted}"
                                       FontSize="17" FontAttributes="Bold"
                                       TextColor="#FFFFFF" />
                                <Label Text="{Binding SelectedItem.TargetMonthFormatted}"
                                       IsVisible="{Binding SelectedItem.TargetMonthFormatted, Converter={StaticResource StringToBool}}"
                                       FontSize="12" TextColor="#CCFFFFFF" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- No-photo fallback: same info, plain layout, no overlay -->
                        <VerticalStackLayout Padding="18,18,18,0" Spacing="6"
                                             IsVisible="{Binding SelectedItem.HasPhoto, Converter={StaticResource InverseBool}}">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding SelectedItem.PriorityLabel}"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="{DynamicResource AccentColor}" />
                                <Label Text="·" FontSize="11"
                                       TextColor="{DynamicResource TextSecondary}" />
                                <Label Text="{Binding SelectedItem.CategoryLabel}"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="{DynamicResource TextSecondary}"
                                       TextTransform="Uppercase" CharacterSpacing="0.4" />
                            </HorizontalStackLayout>

                            <Label Text="{Binding SelectedItem.Name}"
                                   FontSize="18" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                            <Label Text="{Binding SelectedItem.PriceFormatted}"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{DynamicResource AccentColor}" />
                            <Label Text="{Binding SelectedItem.TargetMonthFormatted}"
                                   IsVisible="{Binding SelectedItem.TargetMonthFormatted, Converter={StaticResource StringToBool}}"
                                   FontSize="12" TextColor="{DynamicResource TextSecondary}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Padding="18,14,18,18" Spacing="6">

                            <Label Text="{Binding SelectedItem.Caption}"
                                   IsVisible="{Binding SelectedItem.HasCaption}"
                                   FontSize="12" TextColor="{DynamicResource TextSecondary}" />

                            <Border IsVisible="{Binding ShowAffordResult}"
                                    BackgroundColor="{Binding AffordResult.CanAfford, Converter={StaticResource BoolToAffordBg}}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    Padding="10,6" Margin="0,2,0,0">
                                <Label Text="{Binding AffordResult.Label}" FontSize="11"
                                       TextColor="{Binding AffordResult.CanAfford, Converter={StaticResource BoolToAffordText}}" />
                            </Border>

                            <BoxView HeightRequest="0.5" Color="{DynamicResource CardBorder}"
                                     Margin="0,8,0,8" />

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Status" FontSize="11"
                                       TextColor="{DynamicResource TextSecondary}" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                    <Border Grid.Column="0" Style="{StaticResource HoverButton}"
                                            BackgroundColor="{Binding SelectedItem.Status, Converter={StaticResource StatusToPlannedBg}}"
                                            Stroke="{DynamicResource CardBorder}" StrokeThickness="0.8"
                                            StrokeShape="RoundRectangle 10" Padding="0,9">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleStatusCommand}"
                                                                  CommandParameter="Planned" />
                                            <PointerGestureRecognizer PointerPressed="DetailButton_PointerPressed"
                                                                      PointerReleased="DetailButton_PointerReleased" />
                                        </Border.GestureRecognizers>
                                        <Label Text="Planned" FontSize="12" HorizontalOptions="Center"
                                               TextColor="{Binding SelectedItem.Status, Converter={StaticResource StatusToPlannedText}}" />
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource HoverButton}"
                                            BackgroundColor="{Binding SelectedItem.Status, Converter={StaticResource StatusToBoughtBg}}"
                                            Stroke="{DynamicResource CardBorder}" StrokeThickness="0.8"
                                            StrokeShape="RoundRectangle 10" Padding="0,9">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleStatusCommand}"
                                                                  CommandParameter="Bought" />
                                            <PointerGestureRecognizer PointerPressed="DetailButton_PointerPressed"
                                                                      PointerReleased="DetailButton_PointerReleased" />
                                        </Border.GestureRecognizers>
                                        <Label Text="✓ Bought" FontSize="12" HorizontalOptions="Center"
                                               TextColor="{Binding SelectedItem.Status, Converter={StaticResource StatusToBoughtText}}" />
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>

                            <VerticalStackLayout IsVisible="{Binding SelectedItem.IsBought}"
                                                 Spacing="6" Margin="0,6,0,0">
                                <Label Text="Worth It?" FontSize="11"
                                       TextColor="{DynamicResource TextSecondary}" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                    <Border Grid.Column="0" Style="{StaticResource HoverButton}"
                                            BackgroundColor="{Binding SelectedItem.RegretRating, Converter={StaticResource RegretRatingToBg}, ConverterParameter=Worth}"
                                            Stroke="{Binding SelectedItem.RegretRating, Converter={StaticResource RegretRatingToStroke}, ConverterParameter=Worth}"
                                            StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                            Padding="0,8">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SetRegretCommand}"
                                                                  CommandParameter="Worth" />
                                            <PointerGestureRecognizer PointerPressed="DetailButton_PointerPressed"
                                                                      PointerReleased="DetailButton_PointerReleased" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="4" HorizontalOptions="Center" VerticalOptions="Center">

                                            <Label Style="{StaticResource PhosphorIcon}"
                                               Text="{x:Static ph:PhosphorIcons.ThumbsUp}"
                                               FontSize="20"
                                               TextColor="{Binding SelectedItem.RegretRating, Converter={StaticResource RegretRatingToText}, ConverterParameter=Worth}" />

                                            <Label Text="Worth it"
                                               FontSize="12"
                                               VerticalOptions="Center"
                                               TextColor="{Binding SelectedItem.RegretRating, Converter={StaticResource RegretRatingToText}, ConverterParameter=Worth}" />

                                        </HorizontalStackLayout>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource HoverButton}"
                                            BackgroundColor="{Binding SelectedItem.RegretRating, Converter={StaticResource RegretRatingToBg}, ConverterParameter=Regret}"
                                            Stroke="{Binding SelectedItem.RegretRating, Converter={StaticResource RegretRatingToStroke}, ConverterParameter=Regret}"
                                            StrokeThickness="0.8" StrokeShape="RoundRectangle 10"
                                            Padding="0,8">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SetRegretCommand}"
                                                                  CommandParameter="Regret" />
                                            <PointerGestureRecognizer PointerPressed="DetailButton_PointerPressed"
                                                                      PointerReleased="DetailButton_PointerReleased" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="4" HorizontalOptions="Center" VerticalOptions="Center">

                                            <Label Style="{StaticResource PhosphorIcon}"
                                               Text="{x:Static ph:PhosphorIcons.ThumbsDown}"
                                               FontSize="20"
                                               TextColor="{Binding SelectedItem.RegretRating, Converter={StaticResource RegretRatingToText}, ConverterParameter=Regret}" />

                                            <Label Text="Regret"
                                               FontSize="12"
                                               VerticalOptions="Center"
                                               TextColor="{Binding SelectedItem.RegretRating, Converter={StaticResource RegretRatingToText}, ConverterParameter=Regret}" />

                                        </HorizontalStackLayout>
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>

                            <Border IsVisible="{Binding SelectedItem.IsBought}"
                                    Style="{StaticResource HoverButton}"
                                    BackgroundColor="{DynamicResource AccentColor}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                    Padding="0,11" Margin="0,8,0,0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ConvertToExpenseCommand}" />
                                    <PointerGestureRecognizer PointerPressed="DetailButton_PointerPressed"
                                                              PointerReleased="DetailButton_PointerReleased" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">

                                    <Label Style="{StaticResource PhosphorIcon}"
                                               Text="{x:Static ph:PhosphorIcons.Receipt}"
                                               FontSize="18"
                                               TextColor="{DynamicResource OnAccentColor}" />

                                    <Label Text="Move to Expenses"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource OnAccentColor}"
                                       VerticalOptions="Center" />

                                </HorizontalStackLayout>
                            </Border>

                            <BoxView HeightRequest="0.5" Color="{DynamicResource CardBorder}"
                                     Margin="0,10,0,4" />

                            <Grid ColumnDefinitions="*,*">
                                <Border Grid.Column="0" Style="{StaticResource HoverButton}"
                                        BackgroundColor="Transparent"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                        Padding="8,6" HorizontalOptions="Start">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding PinItemCommand}" />
                                        <PointerGestureRecognizer PointerPressed="DetailButton_PointerPressed"
                                                                  PointerReleased="DetailButton_PointerReleased" />
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                        <Label Style="{StaticResource PhosphorIcon}"
                                               Text="{Binding SelectedItem.IsPinned, Converter={StaticResource BoolToPinIcon}}"
                                               FontSize="14"
                                               TextColor="{DynamicResource TextSecondary}" />

                                        <Label Text="{Binding SelectedItem.IsPinned, Converter={StaticResource BoolToPinLabel}}"
                                               FontSize="12" VerticalOptions="Center"
                                               TextColor="{DynamicResource TextSecondary}" />

                                    </HorizontalStackLayout>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource HoverButton}"
                                        BackgroundColor="Transparent"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                        Padding="8,6" HorizontalOptions="End">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding DeleteWishItemCommand}" />
                                        <PointerGestureRecognizer PointerPressed="DetailButton_PointerPressed"
                                                                  PointerReleased="DetailButton_PointerReleased" />
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="4" VerticalOptions="Center">

                                        <Label Style="{StaticResource PhosphorIcon}"
                                               Text="{x:Static ph:PhosphorIcons.Delete}"
                                               FontSize="14"
                                               TextColor="#c0392b" />

                                        <Label Text="Remove" FontSize="12"
                                               TextColor="#c0392b" />

                                    </HorizontalStackLayout>
                                </Border>
                            </Grid>

                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <Border BackgroundColor="#33000000"
                        StrokeThickness="0" StrokeShape="RoundRectangle 980"
                        WidthRequest="30" HeightRequest="30"
                        HorizontalOptions="End" VerticalOptions="Start"
                        Margin="0,14,14,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding DismissDetailCommand}" />
                        <PointerGestureRecognizer PointerPressed="DetailButton_PointerPressed"
                                                  PointerReleased="DetailButton_PointerReleased" />
                    </Border.GestureRecognizers>
                    <Label Text="✕" FontSize="13" FontAttributes="Bold"
                           TextColor="#FFFFFF"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                </Grid>
            </Border>
        </controls:DrawerHost.DrawerContent>
    </controls:DrawerHost>
</ContentPage>
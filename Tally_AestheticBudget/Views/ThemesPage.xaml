<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Tally_AestheticBudget.Views.ThemesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Tally_AestheticBudget.ViewModels"
    xmlns:models="clr-namespace:Tally_AestheticBudget.Models"
    x:DataType="vm:ThemesViewModel"
    Shell.NavBarIsVisible="True"
    BackgroundColor="{DynamicResource PageBackground}">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- ── Page header ─────────────────────────────────────────── -->
                <Border BackgroundColor="{DynamicResource CardBackground}"
                        Stroke="{DynamicResource CardBorder}"
                        StrokeThickness="1" StrokeShape="RoundRectangle 20"
                        Padding="20,18,20,16"
                        Margin="16,16,16,0">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Themes" FontFamily="DisplayFont"
                               FontSize="28" TextColor="{DynamicResource TextPrimary}" />
                        <Label Text="Pick a vibe for your app"
                               FontSize="13" TextColor="{DynamicResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Padding="16,16,16,48" Spacing="12">

                    <!-- ── Preset themes ──────────────────────────────────── -->
                    <Border BackgroundColor="{DynamicResource CardBackground}"
                            Stroke="{DynamicResource CardBorder}"
                            StrokeThickness="1" StrokeShape="RoundRectangle 20"
                            Padding="20,20">
                        <VerticalStackLayout Spacing="14">

                            <VerticalStackLayout Spacing="2">
                                <Label Text="Presets" FontSize="16" FontAttributes="Bold"
                                       TextColor="{DynamicResource TextPrimary}" />
                                <Label Text="Tap a theme to apply it"
                                       FontSize="12" TextColor="{DynamicResource TextSecondary}" />
                            </VerticalStackLayout>

                            <!-- 6-column Apple Music–style portrait swatch grid -->
                            <CollectionView ItemsSource="{Binding ThemeCards}"
                                           SelectionMode="None">
                                <CollectionView.ItemsLayout>
                                    <GridItemsLayout Orientation="Vertical" Span="6"
                                                     HorizontalItemSpacing="8"
                                                     VerticalItemSpacing="8" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ThemeCardItem">
                                        <ContentView>
                                            <ContentView.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ThemesViewModel}}, Path=ApplyThemeCommand}"
                                                    CommandParameter="{Binding Id}" />
                                            </ContentView.GestureRecognizers>

                                            <!--
                                                Outer card: gradient fills the full face.
                                                StrokeShape clips children to rounded rect,
                                                so the scrim and label respect the corners.
                                            -->
                                            <Border HeightRequest="160"
                                                    StrokeThickness="2"
                                                    Stroke="{Binding IsActive, Converter={StaticResource BoolToChipBorder}}"
                                                    StrokeShape="RoundRectangle 14"
                                                    Padding="0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="{Binding PreviewFrom}" Offset="0.0" />
                                                        <GradientStop Color="{Binding PreviewTo}"   Offset="1.0" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.GestureRecognizers>
                                                    <PointerGestureRecognizer
                                                        PointerEntered="OnThemeCardPointerEntered"
                                                        PointerExited="OnThemeCardPointerExited" />
                                                </Border.GestureRecognizers>

                                                <Grid>
                                                    <!-- Bottom scrim: transparent → dark -->
                                                    <Border StrokeThickness="0"
                                                            VerticalOptions="End"
                                                            HeightRequest="48"
                                                            HorizontalOptions="Fill">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#00000000" Offset="0.0" />
                                                                <GradientStop Color="#CC000000" Offset="1.0" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>

                                                    <!-- Theme name overlaid at bottom -->
                                                    <Label Text="{Binding DisplayName}"
                                                           FontSize="10" FontAttributes="Bold"
                                                           TextColor="White"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="End"
                                                           Margin="4,0,4,8"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="1" />
                                                </Grid>
                                            </Border>
                                        </ContentView>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Custom Palette ─────────────────────────────────── -->
                    <Border BackgroundColor="{DynamicResource CardBackground}"
                            Stroke="{DynamicResource CardBorder}"
                            StrokeThickness="1" StrokeShape="RoundRectangle 20"
                            Padding="20,20">
                        <VerticalStackLayout Spacing="20">

                            <VerticalStackLayout Spacing="4">
                                <Label Text="Custom Palette" FontSize="16" FontAttributes="Bold"
                                       TextColor="{DynamicResource TextPrimary}" />
                                <Label Text="Tap a swatch to edit its color"
                                       FontSize="12" TextColor="{DynamicResource TextSecondary}" />
                            </VerticalStackLayout>

                            <!--
                                4 equal columns, no fixed WidthRequest so each swatch
                                fills its column for consistent spacing.
                            -->
                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">

                                <!-- Background swatch -->
                                <VerticalStackLayout Grid.Column="0" Spacing="8">
                                    <Border BackgroundColor="{Binding CustomBg}"
                                            StrokeThickness="1"
                                            Stroke="{DynamicResource CardBorder}"
                                            StrokeShape="RoundRectangle 14"
                                            HeightRequest="160"
                                            HorizontalOptions="Fill">
                                        <Border.Shadow>
                                            <Shadow Brush="#40000000" Offset="0,4"
                                                    Radius="8" Opacity="0.15" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding OpenColorPickerCommand}" CommandParameter="bg" />
                                            <PointerGestureRecognizer
                                                PointerEntered="OnSwatchPointerEntered"
                                                PointerExited="OnSwatchPointerExited" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Label Text="Background" FontSize="11"
                                           TextColor="{DynamicResource TextSecondary}"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>

                                <!-- Accent swatch -->
                                <VerticalStackLayout Grid.Column="1" Spacing="8">
                                    <Border BackgroundColor="{Binding CustomAccent}"
                                            StrokeThickness="1"
                                            Stroke="{DynamicResource CardBorder}"
                                            StrokeShape="RoundRectangle 14"
                                            HeightRequest="160"
                                            HorizontalOptions="Fill">
                                        <Border.Shadow>
                                            <Shadow Brush="#40000000" Offset="0,4"
                                                    Radius="8" Opacity="0.15" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding OpenColorPickerCommand}" CommandParameter="accent" />
                                            <PointerGestureRecognizer
                                                PointerEntered="OnSwatchPointerEntered"
                                                PointerExited="OnSwatchPointerExited" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Label Text="Accent" FontSize="11"
                                           TextColor="{DynamicResource TextSecondary}"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>

                                <!-- Card swatch -->
                                <VerticalStackLayout Grid.Column="2" Spacing="8">
                                    <Border BackgroundColor="{Binding CustomCard}"
                                            StrokeThickness="1"
                                            Stroke="{DynamicResource CardBorder}"
                                            StrokeShape="RoundRectangle 14"
                                            HeightRequest="160"
                                            HorizontalOptions="Fill">
                                        <Border.Shadow>
                                            <Shadow Brush="#40000000" Offset="0,4"
                                                    Radius="8" Opacity="0.15" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding OpenColorPickerCommand}" CommandParameter="card" />
                                            <PointerGestureRecognizer
                                                PointerEntered="OnSwatchPointerEntered"
                                                PointerExited="OnSwatchPointerExited" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Label Text="Card" FontSize="11"
                                           TextColor="{DynamicResource TextSecondary}"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>

                                <!-- Text swatch -->
                                <VerticalStackLayout Grid.Column="3" Spacing="8">
                                    <Border BackgroundColor="{Binding CustomText}"
                                            StrokeThickness="1"
                                            Stroke="{DynamicResource CardBorder}"
                                            StrokeShape="RoundRectangle 14"
                                            HeightRequest="160"
                                            HorizontalOptions="Fill">
                                        <Border.Shadow>
                                            <Shadow Brush="#40000000" Offset="0,4"
                                                    Radius="8" Opacity="0.15" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding OpenColorPickerCommand}" CommandParameter="text" />
                                            <PointerGestureRecognizer
                                                PointerEntered="OnSwatchPointerEntered"
                                                PointerExited="OnSwatchPointerExited" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Label Text="Text" FontSize="11"
                                           TextColor="{DynamicResource TextSecondary}"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>

                            </Grid>

                            <Border BackgroundColor="{DynamicResource AccentColor}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 980"
                                Padding="36,14"
                                HorizontalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ApplyCustomThemeCommand}" />
                                </Border.GestureRecognizers>
                                <Label Text="Apply Custom Palette" FontSize="15"
                                       FontAttributes="Bold" TextColor="White"
                                       HorizontalOptions="Center" />
                            </Border>

                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Monthly Themes ──────────────────────────────────── -->
                    <Border BackgroundColor="{DynamicResource CardBackground}"
                            Stroke="{DynamicResource CardBorder}"
                            StrokeThickness="1" StrokeShape="RoundRectangle 20"
                            Padding="20,20">
                        <VerticalStackLayout Spacing="16">

                            <VerticalStackLayout Spacing="4">
                                <Label Text="Monthly Themes" FontSize="16" FontAttributes="Bold"
                                       TextColor="{DynamicResource TextPrimary}" />
                                <Label Text="Tap a month to assign a vibe — activates when you view that month in Feed or Budget"
                                       FontSize="12" TextColor="{DynamicResource TextSecondary}" />
                            </VerticalStackLayout>

                            <!-- Year navigation -->
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Grid.Column="0" Style="{StaticResource HoverButton}"
                                        BackgroundColor="{DynamicResource PageBackground}"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                        Padding="12,6">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding PreviousMonthlyYearCommand}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="◀" FontSize="14"
                                           TextColor="{DynamicResource TextSecondary}"
                                           HorizontalOptions="Center" />
                                </Border>
                                <Label Grid.Column="1" Text="{Binding MonthlyYearLabel}"
                                       FontSize="16" FontAttributes="Bold"
                                       TextColor="{DynamicResource TextPrimary}"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                <Border Grid.Column="2" Style="{StaticResource HoverButton}"
                                        BackgroundColor="{DynamicResource PageBackground}"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                        Padding="12,6">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding NextMonthlyYearCommand}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="▶" FontSize="14"
                                           TextColor="{DynamicResource TextSecondary}"
                                           HorizontalOptions="Center" />
                                </Border>
                            </Grid>

                            <!--
                                6-column monthly grid — matches the preset swatch style.
                                Two visual states per card (HasTheme / !HasTheme) are
                                toggled via IsVisible, using the app-level InverseBool converter.
                                Layers render in document order: earliest = bottom, latest = top.
                            -->
                            <CollectionView ItemsSource="{Binding MonthlyItems}"
                                           SelectionMode="None">
                                <CollectionView.ItemsLayout>
                                    <GridItemsLayout Orientation="Vertical" Span="6"
                                                     HorizontalItemSpacing="8"
                                                     VerticalItemSpacing="8" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:MonthlyThemeItem">

                                        <Border StrokeThickness="1"
                                                Stroke="{DynamicResource CardBorder}"
                                                StrokeShape="RoundRectangle 14"
                                                HeightRequest="160"
                                                Padding="0">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ThemesViewModel}}, Path=OpenMonthThemePickerCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>

                                            <Grid>
                                                <!-- ── State A: theme assigned ── -->

                                                <!-- Gradient fill (full card) -->
                                                <Border StrokeThickness="0"
                                                        IsVisible="{Binding HasTheme}"
                                                        HorizontalOptions="Fill"
                                                        VerticalOptions="Fill">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="{Binding PreviewFrom}" Offset="0.0" />
                                                            <GradientStop Color="{Binding PreviewTo}"   Offset="1.0" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>

                                                <!-- Bottom scrim (assigned) -->
                                                <Border StrokeThickness="0"
                                                        IsVisible="{Binding HasTheme}"
                                                        VerticalOptions="End"
                                                        HeightRequest="50"
                                                        HorizontalOptions="Fill">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#00000000" Offset="0.0" />
                                                            <GradientStop Color="#CC000000" Offset="1.0" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>

                                                <!-- Month + theme name (assigned) -->
                                                <VerticalStackLayout
                                                    IsVisible="{Binding HasTheme}"
                                                    VerticalOptions="End"
                                                    HorizontalOptions="Center"
                                                    Spacing="1"
                                                    Margin="4,0,4,7">
                                                    <Label Text="{Binding MonthLabel}"
                                                           FontSize="13" FontAttributes="Bold"
                                                           TextColor="White"
                                                           HorizontalOptions="Center" />
                                                    <Label Text="{Binding AssignedThemeName}"
                                                           FontSize="8"
                                                           TextColor="#D0FFFFFF"
                                                           HorizontalOptions="Center"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="1" />
                                                </VerticalStackLayout>

                                                <!-- ── State B: no theme assigned ── -->

                                                <!-- Muted background -->
                                                <Border BackgroundColor="{DynamicResource PageBackground}"
                                                        StrokeThickness="0"
                                                        IsVisible="{Binding HasTheme, Converter={StaticResource InverseBool}}"
                                                        HorizontalOptions="Fill"
                                                        VerticalOptions="Fill" />

                                                <!-- Month label only (no theme) -->
                                                <Label Text="{Binding MonthLabel}"
                                                       IsVisible="{Binding HasTheme, Converter={StaticResource InverseBool}}"
                                                       FontSize="13" FontAttributes="Bold"
                                                       TextColor="{DynamicResource TextSecondary}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />

                                            </Grid>
                                        </Border>

                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- Color Picker Overlay — unchanged                                  -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding IsColorPickerVisible}"
              BackgroundColor="#80000000"
              VerticalOptions="Fill" HorizontalOptions="Fill">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding DismissColorPickerCommand}" />
            </Grid.GestureRecognizers>

            <Border BackgroundColor="{DynamicResource CardBackground}"
                    StrokeThickness="0" StrokeShape="RoundRectangle 24"
                    Padding="24,24,24,28"
                    VerticalOptions="Center" HorizontalOptions="Center"
                    WidthRequest="380">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPickerCardTapped" />
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="16">

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="{Binding PickerTitle}"
                               FontSize="17" FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}" />
                        <Border Grid.Column="1"
                                BackgroundColor="{DynamicResource PageBackground}"
                                StrokeThickness="0" StrokeShape="RoundRectangle 980"
                                WidthRequest="28" HeightRequest="28">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding DismissColorPickerCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="✕" FontSize="12"
                                   TextColor="{DynamicResource TextSecondary}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <Border BackgroundColor="{DynamicResource PageBackground}"
                            Stroke="{DynamicResource CardBorder}"
                            StrokeThickness="1" StrokeShape="RoundRectangle 12">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry Grid.Column="0"
                                   Text="{Binding PickerHexInput}"
                                   Placeholder="#ffffff" PlaceholderColor="#C0C0C5"
                                   FontSize="14" FontFamily="BodyFont"
                                   TextColor="{DynamicResource TextPrimary}"
                                   BackgroundColor="Transparent"
                                   HeightRequest="46" VerticalOptions="Center"
                                   Margin="14,0,8,0" />
                            <Border Grid.Column="1"
                                    BackgroundColor="{DynamicResource AccentColor}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                    WidthRequest="72" HeightRequest="36"
                                    VerticalOptions="Center" Margin="0,0,5,0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ApplyHexInputCommand}" />
                                </Border.GestureRecognizers>
                                <Label Text="Apply" FontSize="13" FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <Label Text="Or pick a color below"
                           FontSize="12" TextColor="{DynamicResource TextSecondary}" />

                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Border BackgroundColor="#ffffff" StrokeThickness="0.5" Stroke="{DynamicResource CardBorder}" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#ffffff"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#f5f5f7" StrokeThickness="0.5" Stroke="{DynamicResource CardBorder}" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#f5f5f7"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#fff0f5" StrokeThickness="0.5" Stroke="{DynamicResource CardBorder}" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#fff0f5"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#f2ede8" StrokeThickness="0.5" Stroke="{DynamicResource CardBorder}" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#f2ede8"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#eef4fb" StrokeThickness="0.5" Stroke="{DynamicResource CardBorder}" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#eef4fb"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#edf4ee" StrokeThickness="0.5" Stroke="{DynamicResource CardBorder}" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#edf4ee"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#0f0f14" StrokeThickness="0.5" Stroke="{DynamicResource CardBorder}" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#0f0f14"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Border BackgroundColor="#ff6b6b" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#ff6b6b"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#e8739a" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#e8739a"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#ff3b30" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#ff3b30"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#ff2d55" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#ff2d55"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#c0392b" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#c0392b"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#fd79a8" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#fd79a8"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#e84393" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#e84393"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Border BackgroundColor="#a78bfa" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#a78bfa"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#9b59b6" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#9b59b6"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#6c5ce7" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#6c5ce7"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#3a8fc4" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#3a8fc4"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#0984e3" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#0984e3"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#12cbc4" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#12cbc4"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#006266" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#006266"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Border BackgroundColor="#4a9e5c" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#4a9e5c"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#00b894" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#00b894"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#55efc4" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#55efc4"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#a0714f" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#a0714f"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#e67e22" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#e67e22"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#fdcb6e" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#fdcb6e"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#f9ca24" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#f9ca24"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Border BackgroundColor="#1d1d1f" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#1d1d1f"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#2c1f14" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#2c1f14"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#0d2a40" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#0d2a40"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#1a2e1c" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#1a2e1c"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#2d3436" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#2d3436"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#636e72" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#636e72"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border BackgroundColor="#b2bec3" StrokeThickness="0" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectColorCommand}" CommandParameter="#b2bec3"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- Month Theme Picker Overlay — unchanged                            -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding IsMonthPickerVisible}"
              BackgroundColor="#80000000"
              VerticalOptions="Fill" HorizontalOptions="Fill">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding DismissMonthPickerCommand}" />
            </Grid.GestureRecognizers>

            <Border BackgroundColor="{DynamicResource CardBackground}"
                    StrokeThickness="0" StrokeShape="RoundRectangle 24"
                    Padding="20,20,20,24"
                    VerticalOptions="Center" HorizontalOptions="Center"
                    WidthRequest="320" MaximumHeightRequest="460">
                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="2">
                        <Label Text="{Binding EditingMonth.MonthLabel, StringFormat='Theme for {0}'}"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}" />
                        <Label Text="Choose which theme to use this month"
                               FontSize="12"
                               TextColor="{DynamicResource TextSecondary}" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="0.5"
                             Color="{DynamicResource CardBorder}" />

                    <CollectionView ItemsSource="{Binding ThemePickerOptions}"
                                   SelectionMode="None"
                                   MaximumHeightRequest="320">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ThemePickerOption">
                                <Border BackgroundColor="Transparent"
                                        StrokeThickness="0" Padding="10,9">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ThemesViewModel}}, Path=SelectMonthThemeCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0"
                                               Text="{Binding DisplayName}"
                                               FontSize="14"
                                               TextColor="{DynamicResource TextPrimary}"
                                               VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="✓"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="{DynamicResource AccentColor}"
                                               IsVisible="{Binding IsSelected}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>

</ContentPage>

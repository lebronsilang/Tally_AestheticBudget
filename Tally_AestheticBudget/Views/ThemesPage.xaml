<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Tally_AestheticBudget.Views.ThemesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Tally_AestheticBudget.ViewModels"
    xmlns:models="clr-namespace:Tally_AestheticBudget.Models"
    x:DataType="vm:ThemesViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource PageBackground}">

    <Grid>

        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <VerticalStackLayout BackgroundColor="{StaticResource CardBackground}"
                                     Padding="24,20,24,20" Spacing="2">
                    <Label Text="Aesthetic Themes" FontFamily="DisplayFont"
                           FontSize="28" TextColor="{StaticResource TextPrimary}" />
                    <Label Text="Pick a vibe for your app"
                           FontSize="13" TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>

                <BoxView HeightRequest="0.5" Color="{StaticResource CardBorder}" />

                <VerticalStackLayout Padding="20,24,20,48" Spacing="24">

                    <Label Text="Presets" FontSize="16" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />

                    <CollectionView ItemsSource="{Binding ThemeCards}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="3"
                                             HorizontalItemSpacing="12" VerticalItemSpacing="12" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ThemeCardItem">
                                <ContentView>
                                    <ContentView.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ThemesViewModel}}, Path=ApplyThemeCommand}"
                                            CommandParameter="{Binding Id}" />
                                    </ContentView.GestureRecognizers>
                                    <Border BackgroundColor="{StaticResource CardBackground}"
                                            StrokeThickness="2"
                                            Stroke="{Binding IsActive, Converter={StaticResource BoolToChipBorder}}"
                                            StrokeShape="RoundRectangle 16"
                                            Padding="10,10,10,12">
                                        <Border.GestureRecognizers>
                                            <PointerGestureRecognizer
                                                PointerEntered="OnThemeCardPointerEntered"
                                                PointerExited="OnThemeCardPointerExited" />
                                        </Border.GestureRecognizers>
                                        <VerticalStackLayout Spacing="8">
                                            <Border HeightRequest="56" StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 10">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="{Binding PreviewFrom}" Offset="0.0" />
                                                        <GradientStop Color="{Binding PreviewTo}"   Offset="1.0" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Label Text="{Binding DisplayName}" FontSize="11"
                                                   FontAttributes="{Binding IsActive, Converter={StaticResource BoolToFontAttr}}"
                                                   HorizontalOptions="Center"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>
                                    </Border>
                                </ContentView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <BoxView HeightRequest="0.5" Color="{StaticResource CardBorder}" />

                    <Label Text="Custom Palette" FontSize="16" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />

                    <Border BackgroundColor="{StaticResource CardBackground}"
                            Stroke="{StaticResource CardBorder}"
                            StrokeThickness="1" StrokeShape="RoundRectangle 16"
                            Padding="24,20">
                        <VerticalStackLayout Spacing="16">

                            <Label Text="Tap a swatch to edit its color"
                                   FontSize="12" TextColor="{StaticResource TextSecondary}" />

                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">

                                <!-- Background -->
                                <VerticalStackLayout Grid.Column="0" Spacing="8" HorizontalOptions="Center">
                                    <Border BackgroundColor="{Binding CustomBg}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 14"
                                            WidthRequest="64" HeightRequest="64"
                                            HorizontalOptions="Center">
                                        <Border.Shadow>
                                            <Shadow Brush="#40000000" Offset="0,4" Radius="8" Opacity="0.18" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnBgSwatchTapped" />
                                            <PointerGestureRecognizer
                                                PointerEntered="OnSwatchPointerEntered"
                                                PointerExited="OnSwatchPointerExited" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Label Text="Background" FontSize="11"
                                           TextColor="{StaticResource TextSecondary}"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>

                                <!-- Accent -->
                                <VerticalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="Center">
                                    <Border BackgroundColor="{Binding CustomAccent}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 14"
                                            WidthRequest="64" HeightRequest="64"
                                            HorizontalOptions="Center">
                                        <Border.Shadow>
                                            <Shadow Brush="#40000000" Offset="0,4" Radius="8" Opacity="0.18" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnAccentSwatchTapped" />
                                            <PointerGestureRecognizer
                                                PointerEntered="OnSwatchPointerEntered"
                                                PointerExited="OnSwatchPointerExited" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Label Text="Accent" FontSize="11"
                                           TextColor="{StaticResource TextSecondary}"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>

                                <!-- Card -->
                                <VerticalStackLayout Grid.Column="2" Spacing="8" HorizontalOptions="Center">
                                    <Border BackgroundColor="{Binding CustomCard}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 14"
                                            WidthRequest="64" HeightRequest="64"
                                            HorizontalOptions="Center">
                                        <Border.Shadow>
                                            <Shadow Brush="#40000000" Offset="0,4" Radius="8" Opacity="0.18" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnCardSwatchTapped" />
                                            <PointerGestureRecognizer
                                                PointerEntered="OnSwatchPointerEntered"
                                                PointerExited="OnSwatchPointerExited" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Label Text="Card" FontSize="11"
                                           TextColor="{StaticResource TextSecondary}"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>

                                <!-- Text -->
                                <VerticalStackLayout Grid.Column="3" Spacing="8" HorizontalOptions="Center">
                                    <Border BackgroundColor="{Binding CustomText}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 14"
                                            WidthRequest="64" HeightRequest="64"
                                            HorizontalOptions="Center">
                                        <Border.Shadow>
                                            <Shadow Brush="#40000000" Offset="0,4" Radius="8" Opacity="0.18" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnTextSwatchTapped" />
                                            <PointerGestureRecognizer
                                                PointerEntered="OnSwatchPointerEntered"
                                                PointerExited="OnSwatchPointerExited" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Label Text="Text" FontSize="11"
                                           TextColor="{StaticResource TextSecondary}"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>

                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Apply button -->
                    <Border BackgroundColor="{StaticResource AccentColor}" StrokeThickness="0"
                            StrokeShape="RoundRectangle 980" Padding="0,16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ApplyCustomThemeCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="Apply Custom Palette" FontSize="15" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" />
                    </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Color Picker Overlay ── -->
        <Grid x:Name="PickerOverlay"
              IsVisible="False"
              BackgroundColor="#80000000"
              VerticalOptions="Fill"
              HorizontalOptions="Fill">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnPickerOverlayTapped" />
            </Grid.GestureRecognizers>

            <Border BackgroundColor="{StaticResource CardBackground}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="24,24,24,28"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    WidthRequest="360">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPickerCardTapped" />
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="20">

                    <Label x:Name="PickerTitle"
                           FontSize="17" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />

                    <Border x:Name="PickerPreview"
                            HeightRequest="56" StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="#ff6b6b" />

                    <Border BackgroundColor="{StaticResource PageBackground}"
                            Stroke="{StaticResource CardBorder}"
                            StrokeThickness="1" StrokeShape="RoundRectangle 12"
                            Padding="16,0">
                        <Entry x:Name="PickerEntry"
                               Placeholder="#ffffff"
                               PlaceholderColor="#C0C0C5"
                               FontSize="15" FontFamily="BodyFont"
                               TextColor="{StaticResource TextPrimary}"
                               BackgroundColor="Transparent"
                               HeightRequest="48"
                               TextChanged="OnPickerEntryChanged" />
                    </Border>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Presets" FontSize="12"
                               TextColor="{StaticResource TextSecondary}" />
                        <FlexLayout Wrap="Wrap" JustifyContent="Start">
                            <Border WidthRequest="32" HeightRequest="32" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8" BackgroundColor="#ffffff"
                                    Margin="0,0,8,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPresetChipTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border WidthRequest="32" HeightRequest="32" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8" BackgroundColor="#f5f5f7"
                                    Margin="0,0,8,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPresetChipTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border WidthRequest="32" HeightRequest="32" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8" BackgroundColor="#1d1d1f"
                                    Margin="0,0,8,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPresetChipTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border WidthRequest="32" HeightRequest="32" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8" BackgroundColor="#0f0f14"
                                    Margin="0,0,8,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPresetChipTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border WidthRequest="32" HeightRequest="32" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8" BackgroundColor="#ff6b6b"
                                    Margin="0,0,8,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPresetChipTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border WidthRequest="32" HeightRequest="32" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8" BackgroundColor="#e8739a"
                                    Margin="0,0,8,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPresetChipTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border WidthRequest="32" HeightRequest="32" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8" BackgroundColor="#a0714f"
                                    Margin="0,0,8,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPresetChipTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border WidthRequest="32" HeightRequest="32" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8" BackgroundColor="#3a8fc4"
                                    Margin="0,0,8,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPresetChipTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border WidthRequest="32" HeightRequest="32" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8" BackgroundColor="#4a9e5c"
                                    Margin="0,0,8,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPresetChipTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border WidthRequest="32" HeightRequest="32" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8" BackgroundColor="#a78bfa"
                                    Margin="0,0,8,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPresetChipTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border WidthRequest="32" HeightRequest="32" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8" BackgroundColor="#fff0f5"
                                    Margin="0,0,8,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPresetChipTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border WidthRequest="32" HeightRequest="32" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8" BackgroundColor="#f2ede8"
                                    Margin="0,0,8,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPresetChipTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border WidthRequest="32" HeightRequest="32" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8" BackgroundColor="#eef4fb"
                                    Margin="0,0,8,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPresetChipTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border WidthRequest="32" HeightRequest="32" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8" BackgroundColor="#edf4ee"
                                    Margin="0,0,8,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPresetChipTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                        </FlexLayout>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource PageBackground}"
                                Stroke="{StaticResource CardBorder}"
                                StrokeThickness="1" StrokeShape="RoundRectangle 12"
                                Padding="0,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPickerCancel" />
                            </Border.GestureRecognizers>
                            <Label Text="Cancel" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalOptions="Center" />
                        </Border>
                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource AccentColor}"
                                StrokeThickness="0" StrokeShape="RoundRectangle 12"
                                Padding="0,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPickerConfirm" />
                            </Border.GestureRecognizers>
                            <Label Text="Apply" FontSize="14" FontAttributes="Bold"
                                   TextColor="White" HorizontalOptions="Center" />
                        </Border>
                    </Grid>

                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>

</ContentPage>
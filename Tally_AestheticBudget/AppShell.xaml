<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Tally_AestheticBudget.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Tally_AestheticBudget.Views">

    <!--
        TabBar gives us the bottom navigation.
        We'll add more tabs (Add, Budget, Wishlist, Grocery) as we build them.
        For now just Feed so you can get it running.
    -->
    <TabBar>

        <Tab Title="Feed" Icon="feed_icon.png">
            <ShellContent
                ContentTemplate="{DataTemplate views:FeedPage}"
                Route="FeedPage" />
        </Tab>

    </TabBar>

</Shell>

<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Tally_AestheticBudget.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Tally_AestheticBudget.Views">

    <TabBar>

        <Tab Title="Feed" Icon="dotnet_bot.png">
            <ShellContent
                ContentTemplate="{DataTemplate views:FeedPage}"
                Route="FeedPage" />
        </Tab>

        <Tab Title="Budget" Icon="dotnet_bot.png">
            <ShellContent
                ContentTemplate="{DataTemplate views:BudgetPage}"
                Route="BudgetPage" />
        </Tab>

        <Tab Title="Grocery" Icon="dotnet_bot.png">
            <ShellContent
                ContentTemplate="{DataTemplate views:GroceryPage}"
                Route="GroceryPage" />
        </Tab>

        <Tab Title="Wishlist" Icon="dotnet_bot.png">
            <ShellContent
                ContentTemplate="{DataTemplate views:WishlistPage}"
                Route="WishlistPage" />
        </Tab>

        <Tab Title="Themes" Icon="dotnet_bot.png">
            <ShellContent
                ContentTemplate="{DataTemplate views:ThemesPage}"
                Route="ThemesPage" />
        </Tab>

    </TabBar>

</Shell>

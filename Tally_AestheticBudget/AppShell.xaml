<?xml version="1.0" encoding="UTF-8"?>
<Shell
    x:Class="Tally_AestheticBudget.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Tally_AestheticBudget.Views"
    Shell.TabBarIsVisible="False"
    Shell.NavBarIsVisible="True"
    Shell.BackgroundColor="{DynamicResource CardBackground}">

    <Shell.TitleView>
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0"
              BackgroundColor="{DynamicResource CardBackground}"
              Padding="16,0">

            <!-- Brand / filter header -->
            <HorizontalStackLayout x:Name="HeaderInfo" Grid.Column="0" Spacing="4" VerticalOptions="Center">
                <Label Text="{Binding Text}" FontFamily="DisplayFont" FontSize="18"
                       TextColor="{DynamicResource AccentColor}" VerticalOptions="Center" />
                <Label Text="✦" FontSize="14" IsVisible="{Binding ShowBrandMark}"
                       TextColor="{DynamicResource AccentColor}" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <!-- Navigation tabs -->
            <HorizontalStackLayout Grid.Column="1" Spacing="4"
                                   HorizontalOptions="Center" VerticalOptions="Center">

                <!-- Feed -->
                <Border x:Name="TabFeed"
                        BackgroundColor="Transparent" StrokeThickness="0"
                        StrokeShape="RoundRectangle 980" Padding="14,6">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="FeedPage" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                        <!-- receipt  U+E3EC -->
                        <Label x:Name="TabFeedIcon" Text="&#xE3EC;" FontFamily="PhosphorIcons"
                               FontSize="16" TextColor="{DynamicResource TextSecondary}"
                               VerticalOptions="Center" />
                        <Label x:Name="TabFeedLabel" Text="Feed" FontSize="13"
                               TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Budget -->
                <Border x:Name="TabBudget"
                        BackgroundColor="Transparent" StrokeThickness="0"
                        StrokeShape="RoundRectangle 980" Padding="14,6">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="BudgetPage" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                        <!-- wallet  U+E68A -->
                        <Label x:Name="TabBudgetIcon" Text="&#xE68A;" FontFamily="PhosphorIcons"
                               FontSize="16" TextColor="{DynamicResource TextSecondary}"
                               VerticalOptions="Center" />
                        <Label x:Name="TabBudgetLabel" Text="Budget" FontSize="13"
                               TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Wishlist -->
                <Border x:Name="TabWishlist"
                        BackgroundColor="Transparent" StrokeThickness="0"
                        StrokeShape="RoundRectangle 980" Padding="14,6">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="WishlistPage" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                        <!-- heart  U+E2A8 -->
                        <Label x:Name="TabWishlistIcon" Text="&#xE2A8;" FontFamily="PhosphorIcons"
                               FontSize="16" TextColor="{DynamicResource TextSecondary}"
                               VerticalOptions="Center" />
                        <Label x:Name="TabWishlistLabel" Text="Wishlist" FontSize="13"
                               TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Grocery -->
                <Border x:Name="TabGrocery"
                        BackgroundColor="Transparent" StrokeThickness="0"
                        StrokeShape="RoundRectangle 980" Padding="14,6">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="GroceryPage" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                        <!-- basket  U+E964 -->
                        <Label x:Name="TabGroceryIcon" Text="&#xE964;" FontFamily="PhosphorIcons"
                               FontSize="16" TextColor="{DynamicResource TextSecondary}"
                               VerticalOptions="Center" />
                        <Label x:Name="TabGroceryLabel" Text="Grocery" FontSize="13"
                               TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Themes -->
                <Border x:Name="TabThemes"
                        BackgroundColor="Transparent" StrokeThickness="0"
                        StrokeShape="RoundRectangle 980" Padding="14,6">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="ThemesPage" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                        <!-- palette  U+E6C8 -->
                        <Label x:Name="TabThemesIcon" Text="&#xE6C8;" FontFamily="PhosphorIcons"
                               FontSize="16" TextColor="{DynamicResource TextSecondary}"
                               VerticalOptions="Center" />
                        <Label x:Name="TabThemesLabel" Text="Themes" FontSize="13"
                               TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Settings -->
                <Border x:Name="TabSettings"
                        BackgroundColor="Transparent" StrokeThickness="0"
                        StrokeShape="RoundRectangle 980" Padding="14,6">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="SettingsPage" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                        <!-- gear  U+E270 -->
                        <Label x:Name="TabSettingsIcon" Text="&#xE270;" FontFamily="PhosphorIcons"
                               FontSize="16" TextColor="{DynamicResource TextSecondary}"
                               VerticalOptions="Center" />
                        <Label x:Name="TabSettingsLabel" Text="Settings" FontSize="13"
                               TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

            </HorizontalStackLayout>

            <BoxView Grid.Column="2" WidthRequest="80" BackgroundColor="Transparent" />

        </Grid>
    </Shell.TitleView>

    <TabBar x:Name="MainTabBar">

        <Tab x:Name="FeedTab" Title="Feed">
            <ShellContent ContentTemplate="{DataTemplate views:FeedPage}"
                          Route="FeedPage" />
        </Tab>

        <Tab x:Name="BudgetTab" Title="Budget">
            <ShellContent ContentTemplate="{DataTemplate views:BudgetPage}"
                          Route="BudgetPage" />
        </Tab>

        <Tab x:Name="GroceryTab" Title="Grocery">
            <ShellContent ContentTemplate="{DataTemplate views:GroceryPage}"
                          Route="GroceryPage" />
        </Tab>

        <Tab x:Name="WishlistTab" Title="Wishlist">
            <ShellContent ContentTemplate="{DataTemplate views:WishlistPage}"
                          Route="WishlistPage" />
        </Tab>

        <Tab x:Name="ThemesTab" Title="Themes">
            <ShellContent ContentTemplate="{DataTemplate views:ThemesPage}"
                          Route="ThemesPage" />
        </Tab>

        <Tab x:Name="SettingsTab" Title="Settings">
            <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}"
                          Route="SettingsPage" />
        </Tab>

    </TabBar>

</Shell>
